// FtpUser.decl - common to FtpKbd* and FtpCli*// Copyright Xerox Corporation 1979, 1980, 1982// Last modified May 13, 1982  3:16 PM by Boggsstructure cmdKTE:[proc wordconReq word]manifest[// list option bitslbCreate = 1b15 rshift offset DPRP.CDATlbRead = 1b15 rshift offset DPRP.RDATlbWrite = 1b15 rshift offset DPRP.WDATlbLength = 1b15 rshift offset DPRP.SIZElbType = 1b15 rshift offset DPRP.TYPElbAuthor = 1b15 rshift offset DPRP.AUTHlbVerbose = lbType % lbLength % lbCreate % lbRead % lbAuthorlbEverything = -1// field widths in characterswName = 25wType = 6wLength = 7wDate = 19wAuthor = 1// cli date controldLS = 4dEQ = 2dGR = 1dLE = dLS + dEQdGE = dGR + dEQdNE = dGR + dLS]