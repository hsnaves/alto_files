// GrapevineInternal.decl// Copyright Xerox Corporation 1981// Last modified January 6, 1982  11:12 AM by Taftstructure GUS:  // Grapevine User State[stream word		// BSP stream to registration serverinUse word		// nonzero if stream in usezone word		// zone for Grapevine package storage allocationsocketHigh word		// high word to use for RServer socket numbers]manifest lenGUS = size GUS/16manifest[// Internal error codes -- clients should never see theseecBadProtocol = 2285	// protocol error, called with Errors on stream// ReturnCode for BSP stream failure -- not in set actually returned by GVrcStreamFailed = 377BrnStreamFailed = 377B// TimeoutsinitialTimeout = 1500	// 15 seconds for initial RFC to R-ServerdataTimeout = 12000	// 2 minutes for request/response to completecloseTimeout = 1000	// 10 seconds  to close connection]