// RSilUtil.bcpl -- Utilities used throughout SIL system // bcpl/f  RSilUtil.bcpl  get "SysDefs.d"get "Sil.defs"let FlushList(link) be[(635)until link eq 0 dol4268[l4268let tl = link>>item.linklink>>item.link = -1link = tll5538]l4268]and IncrementCoords(obj,xinc,yinc) be[obj>>item.xmin = obj>>item.xmin+xincobj>>item.xmax = obj>>item.xmax+xincobj>>item.ymin = obj>>item.ymin+yincobj>>item.ymax = obj>>item.ymax+yincl4268]and Length(block) = valof //returns the length of an item[//if block>>item.font ne 14 then resultis 6+(block>>item.string.length)/2//resultis 5if block>>item.line then resultis 5resultis 6+(block>>item.string.length)/2l4268]// String routines of various sortsand AppendC(char,string) be[let st = string>>str.length +1string>>str.char^st = charstring>>str.length = stl4268]and AppendS(sts,std) be //copy from source to destination[for i = 1 to sts>>str.length do AppendC(sts>>str.char^i,std)l4269]and AppendN(num,str) be //decimal number - no leading spaces[let chout = falselet digit = 10000 for i = 4 to 0 by -1 do[l4268let ch = (num/digit) + $0if ch ne $0 % chout % i eq 0 then [ AppendC(ch,str); chout = true ] num = num rem digitdigit = digit / 10l5539]l4269]