// Main error handling stuff.// Copyright Xerox Corporation 1979// Last modified August 28, 1979  5:35 PM by Boggsexternal SysErrT//---------------------------------------------------------------------------let SysErrT(p1, errNo, p2, p3, p4, p5; numargs na) be//---------------------------------------------------------------------------// This is the 'true' SysErr.// The static SysErr is defined in Level012.asm.// BootInit copies SysErrT into SysErr.[let t = p1; p1 = errNo; errNo = t(table [ #77403; #1401 ])("Sys.Errors", lv p1)]