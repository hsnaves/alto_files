// CallFtp -- run it from Sys.Boot// Copyright Xerox Corporation 1979// Last modified August 28, 1979  9:39 PM by Boggsget "SysDefs.d"external EventVector//----------------------------------------------------------------------------let FakeFtp() be//----------------------------------------------------------------------------[let p = EventVectorp>>EVM.type = eventCallSubsysp>>EVM.length = size EVM/16	//No stringp = p + size EVM/16@p = 0finish]