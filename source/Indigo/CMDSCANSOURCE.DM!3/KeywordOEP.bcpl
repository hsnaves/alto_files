// KeywordOEP.bcpl -- overlay entry point declarations for keyword package// Copyright Xerox Corporation 1979//	Last modified October 7, 1977  2:54 PMexternal[//outgoing proceduresInitKeywordOEP//incoming proceduresDeclareOEP; KTInsert; KTDelete; KTLookup; KTEnumerate; KTDestroy; CompareKey]//---------------------------------------------------------------------------let InitKeywordOEP(oev) be//---------------------------------------------------------------------------   DeclareOEP(oev, lv KTInsert, lv KTDelete, lv KTLookup,    lv KTEnumerate, lv KTDestroy, lv CompareKey)