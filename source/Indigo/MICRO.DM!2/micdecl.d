ype = 0mactype = 1		// Not used (Mac symbols have stype=fstop-Def ptr)fldtype = 2inttype = 3adrtype = 4		// For values only (Adr symbols have stype=mem Ep-fstop)bitype = 5neutype = 6memtype = 7undtype = 8bttype = 9maxtype = 9		// Maximum type number// Evaluation Modesvalmode = 1		// Return valueaccmode = 2		// Accumulate wordfldmode = 3		// Field Store// Lexical scan markers - must be control char.sendc = $*Nsepc = $*SAend = 1Aargn = 2Aarg2 = 3Aarg1 = 4Anargs = 5Askip = 6symc = 21numc = 22num6c = 23// Fields in symbolslink = 0		// Offset of hash linkstype = -1		// Offset of typesname = 1		// Offset of name// Displacementsmcsp = -1isval = -2fsbits = -2asmem = -1asval = -2mswidth = -2mssize = -3msno = -4msdflt = -5mssource = -6mssink = -7mslist = -8msltag = -9// msbt = -10 // no longer usedmspost = -11mstagmac = -12mslfields = -13bsno = -2bttab = -2btsize = -3// Block prefix displacementbprefix = -1// LIST flags	LFbinary = 1	LFfields = 2	LFnumeric = 4	LFalphabetic = #10	LF16bit = #20	LFany = LFbinary+LFfields+LF16bit	// list stores if any of these is set// Initial BUILTIN numbers	biBUILTIN = 1	biINSERT = 20// Buffer lengths	stbl = 400	filenamelength = 40// Binary block types	MBend = 0	MBdata = 1	MBseta = 2	MBfixup = 3	MBmemdef = 4	MBsymbol = 5	MBext = 6]// BCPL stringstructure BS:[	length byte	char^1,255 byte]// Bytes in wordstructure [ lh byte; rh byte ]structure [ bytes^0,77777b byte ]