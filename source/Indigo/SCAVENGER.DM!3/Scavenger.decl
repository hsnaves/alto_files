// Scavenger.decl// Copyright Xerox Corporation 1981, 1982// Last modified May 2, 1982  10:52 PM by Boggs//-----------------------------------------------------------------------------------------structure FD:		// File Descriptor//-----------------------------------------------------------------------------------------[sn @SN			// serial numberfirstVDA word		// vda of first pagelastVDA word		// vda of last pagelastPN word		// page number of last pagelastNumChars bit 9	// number of bytes in last pageblank bit 3duplicate bit		// used by scan passregistered bit		// used by directory passstate bit 2		// see below]manifest lenFD = size FD/16manifest [// FD.state values:fdBeingChecked = 0fdToBeChecked = 1fdGood = 2fdBad = 3]