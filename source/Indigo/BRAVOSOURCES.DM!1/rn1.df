// rn1.df// Carol Hankins// March 26, 1976structure RL:	[	krl	word	doc	word = fn	word	rimax	word	rimac	word	mpbirifirst	word	mpbivpa	word	mpbifcfirst	word = mpbicpfirst	word	bimac	word	VpaGet	word	bphint	word	fRes	word	rb	word	last	word	]manifest lrl = (offset RL.last)/16manifest	[	krlf = $f	krld = $d	krlw = $w	nrlmax = 5		//also in font.sr	riEndOfDoc = 10	riTrailer = 62	]structure RX:	[	rifirst	word	dri	word	bi	word	brgdfcfirst	word = brgdcpfirst	word	brgdfc	word = brgdcp	word	brgdfcmax	word	last	word	]manifest lrx = (offset RX.last)/16structure RID:	[	nrl	bit 5	[ ri	bit 11 ]	= [ blank bit 4	fun bit 4	al bit 1	fa bit 2 ]	]structure RD:	[	fc	word = cp	word	dfc	word = dcp	word	dfcmax	word	last	word	]manifest lrd = (offset RD.last)/16manifest rinil = 57	// region number of space