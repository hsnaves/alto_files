// dir.dfstructure NMD:	[ next	word	ldeFree	word	waDeFree	word	waDe	word	verMin	word	verMac	word	vc	word	cver	word	ver	word	afptr	@FP	asbFile	@SB	] structure DE:	[ ty	bit 6	l	bit 10	afptr	@FP	asbFile	@SB	] manifest	[ 	vcExact = 0	vcOldest = 1;	vcNewest = 2	vcNew = 3	vcNewestOrNew = 4	tyDeFree = 0	tyDeFile = 1	ovhNmd = (offset NMD.asbFile)/16	ovhDe = (offset DE.asbFile)/16	lnmdMax = ovhNmd+30	ldeMax = ovhNmd+30	ftyNil = -1; ftyOld = 1; ftyNewFile = 2; ftyNewVer = 3	ftyNewOnDollar = 4; ftyNewOnOld = 5	ftyOverwrite = 6	] 