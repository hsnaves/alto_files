// look.dfstructure ARD:	[	ri	byte	iwFirst	bit 4	iwLast	bit 4	fWhere	bit 1	fHere	bit 1	fSameAs	bit 1	fDefault	bit 1	fTyping	bit 1	fMicas	bit 1	blank	bit 10	]manifest	[	ardNil = -1	ardWhere = #100000	ardHere = #40000	ardSameAs = #20000	ardDefault = #10000	ardTyping = #4000	ardMicas = #2000	ardStdX = ardWhere + ardHere + ardSameAs + ardDefault + ardTyping + ardMicas	ardStdY = ardSameAs + ardDefault + ardTyping	]manifest	[	abSelEmp = 2 lshift (16 - offset AB.crid - size AB.crid) +		0 lshift (16 - offset AB.nrid - size AB.nrid)	abIllParam = 2 lshift (16 - offset AB.crid - size AB.crid) +		2 lshift (16 - offset AB.nrid - size AB.nrid)	abDiabloFont = 2 lshift (16 - offset AB.crid - size AB.crid) +		4 lshift (16 - offset AB.nrid - size AB.nrid)	abIllLook = 2 lshift (16 - offset AB.crid - size AB.crid) +		6 lshift (16 - offset AB.nrid - size AB.nrid)	abNoDefault = 2 lshift (16 - offset AB.crid - size AB.crid) +		8 lshift (16 - offset AB.nrid - size AB.nrid)	abComTerm = 2 lshift (16 - offset AB.crid - size AB.crid) +		10 lshift (16 - offset AB.nrid - size AB.nrid)	abNoEdit = 2 lshift (16 - offset AB.crid - size AB.crid) +		12 lshift (16 - offset AB.nrid - size AB.nrid)	abWhere = -10	abHere = -11	abSameAs = -12	abDefault = -13	abTyping = -14	]manifest	[	iffQuery = iffMax	iffMagnify = iffMax + 1	]