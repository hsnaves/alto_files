// OM.DFstructure OM:	[ cref		bit 3	ffixedstor	bit 1	fp		bit 12	cword		word	ov		word	mn		word	fptr		word	aFa		@FA	];structure OV:	[ blank	word	lncode	word	type	word	reltbl	word	lnmod	word	fp 	word	mn	word	blank	word 10	code	word	];structure RELTBL:	[ cstat		word	rvmpistatrpr	word	];structure RPR:	[ lvstat	word	rpc	word	];manifest	[	lnrpr = (size RPR)/16;	lnovhdr = 16;	lnom = (size OM)/16;	omNil = 0	mnKd = $Q-$A;	];