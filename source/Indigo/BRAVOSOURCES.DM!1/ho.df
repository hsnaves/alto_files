// ho.df// last modified // RML - September 17, 1977  8:08 PM - to add nColor field// RML - April 12, 1978  4:05 PM modified for single page color Press files.structure HO:	[	fPgn	bit 1	fRoman	bit 1	fUppercase	bit 1	fAlternate	bit 1	fXpd	bit 1	fLn	bit 1	fPgRel	bit 1	fNoPgn	bit 1	fNoHdr	bit 1	blank	bit 7	pgnFirst	word	xPgn	word	yPgn	word	xXpd	word	yXpd	word	ccol	word	xwEdgemarg	word	xwMiddlemarg	word	xwBindmarg	word	cpHdrOdd	word	cpHdrEven	word	yStartOfTx	word	yEndOfTx	word	lnFirst	word	lnMod	word	ccopy	word	pgnStartPrint	word	fDiablo	bit 1	fFile	bit 1	fNetAddress	bit 1	fEars	bit 1	fColor	bit 1	// returned by press 	fPrintBy	bit 1	nColor	bit 2		blank	bit 8	lnLast	word	asbPgn	word 10	asbNetAddress	word 10	aslPrintBy	word 20	]manifest	[	lnho = (size HO)/16 + 10	lnhoDefault = (offset HO.ccopy)/16	lnhoCf = (offset HO.lnLast)/16 - lnhoDefault	cwNetAddress = (size HO.asbNetAddress)/16;	cwPrintBy = (size HO.aslPrintBy)/16;	]