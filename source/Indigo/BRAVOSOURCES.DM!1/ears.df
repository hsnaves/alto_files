// EARS.DFstructure FDENT :		//one for each font set	[ strecfm  word		//starting rec of FM ref'd from 1st FM	crecfm word			//number of recs in FM	crecfs word			//number of recs in FS	ttytab word			//[**] who knows	]structure FONTDIR  : [ @FDENT^0,63 ]structure FS:	[ rvmpfefunfa	word	blank		word 15	rvmpfefn	word	= rvmpfedafm	word	blank		word 15	rvmpfenmd	word	= rvmpfedafs	word	blank		word 15	rvmpfesn1	word	blank		word 15	rvmpfesn2	word	blank		word 15	mpfefactive	word	lfm		word	];structure FSE:	[ blank	word 3	height1	bit 1	fontadr	bit 15	];structure PEP:	[ acfaCur	@CFA	daPrev	word	aqbufFree	@Q	aqbufDl	@Q	aqbufTl	@Q	aqbufPd	@Q	daPgn1	word	];structure TLE:	[ di	word	bfcFirst	word	fe128	word	ye8	word	];structure PDE:	[ recFirst	word	cdl	word	ctl	word	fsne	word	];manifest	[ 	lPep = (size PEP)/16	lPde = (size PDE)/16	lTle = (size TLE)/16	fspassword = #20200;	lnrec0 = 64;	lnrec1 = 1024;	lnrec3 = 512;	lnrece = 256;	fenil = -1;	tabnil = 0;	fsnnil = -1;//	funfanil2 = -2;	effcnst = lnrec0+lnrec1+lnrec3;	lnfs = (size FS)/16;	fcrec2 = (lnrec0+lnrec1)*2;	maxfsn = 8;	fsndef = 0;	dFcDOCULIST = #2000	dPgDOCULIST = 2	fcENDLIST = #2000-#11	password = 31415	siztlentry = 8	maxsbtime = 30	lrec2nil= 0	];