// diablo.dfmanifest	[	diabloin = #177030	// printer input address	diabloout = #177016	// printer output address	paper = #100000		// paper feed strobe bit	prcheck = #40000	rest = #40000		// restore bit	ribbonlift = #20000	daisy = #10000		// daisy strobe and ready bit	carriage = #4000		// carriage strobe and ready bit	ready = #2000	allready = #116000	// OR of ready bits	xdPerinch = 60	ydPerinch = 48// for 8.5" x 11" paper	xdMax = 17 * xdPerinch / 2	// paper width in Horiz. Printer Units (HPUs)	ydMax = 11 * ydPerinch	// paper height in Vert. Printer Units (VPUs)	]