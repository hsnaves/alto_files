// vm.dfstructure BUF:	[ next	word	ca	word	bp	word;	pgn	word	numChars	word	] structure SCP:	[ fmCaller	word	qBufRead	word	qBufFree	word	qBufReading	word	fa	word	TcScanProc	word	] structure FPG:	[ hi	bit 9	lo	bit 7	] manifest	[ tcDone = -1	tcNotDone = 0	tcToYou = 1	tcByScanProc = 2	tcByScanPages = 3	tcAbort = 4	tcNil = 5721	lScp = (size SCP)/16	lBuf = (size BUF)/16	] manifest	[ vmtbmask = #37;	chperpage = 512;	maxbp = 15;	minuserfn = 20;	maxfn = 50;	sbfnaml = 50;	fnscr = 1;	fndir = 2;	fnput = 3;	fntsmanifest = 4;	fncom = 5;	fnuser = 6;	fnrem = 7;	fnDiskDesc = 8;	fnom = 9	fnHelp = 10;	fnLog = 11;	fnfont = 12;	fnscrfs = 13;	fnrlf = 14;	fnwindowbb = 15;	fnfontw = 16;	fnmeasure = 17;	ofsiz = (offset OF.last)/16;	bpbuff = 0;	] 