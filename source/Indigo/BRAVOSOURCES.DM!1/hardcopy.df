// hardcopy.dfget "HO.DF"manifest	[	piNil = -1	mictodmlt = 60	mictoddiv = 2540	pttodmlt = 48	pttoddiv = 72	mictoemlt = 25;	mictoediv = 127;	pttoemlt = 125;	pttoediv = 18;	abDiabloFont = 2 lshift (16 - offset AB.crid - size AB.crid) +		0 lshift (16 - offset AB.nrid - size AB.nrid)	abTooLong = 2 lshift (16 - offset AB.crid - size AB.crid) +		2 lshift (16 - offset AB.nrid - size AB.nrid)	abIllChar = 2 lshift (16 - offset AB.crid - size AB.crid) +		4 lshift (16 - offset AB.nrid - size AB.nrid)	abPassword = 2 lshift (16 - offset AB.crid - size AB.crid) +		6 lshift (16 - offset AB.nrid - size AB.nrid)	abIllOpt = 2 lshift (16 - offset AB.crid - size AB.crid) +		8 lshift (16 - offset AB.nrid - size AB.nrid)	abComTerm = 2 lshift (16 - offset AB.crid - size AB.crid) +		10 lshift (16 - offset AB.nrid - size AB.nrid)	abWontRestore = 2 lshift (16 - offset AB.crid - size AB.crid) +		12 lshift (16 - offset AB.nrid - size AB.nrid)	abBadPage = -10	]