-- FloatMCTest.mesal4128d2998(1792)\3b16B-- Copywrite Xerox Corporation 1980z18591l3712d2998j-- Program to check out new Floating arithmeticl4128d2998-- Last Modified: LStewart May 27, 1980  12:54 PMl4128d2998DIRECTORYe12InlineDefs: FROM "InlineDefs",l4704d4268IODefs: FROM "IODefs",l4704d4268Mopcodes: FROM "Mopcodes",l4704d4268RealDefs: FROM "RealDefs",l4704d4268WF: FROM "WF";l4704d4268FloatMCTest: PROGRAMl3658d2998e12\b11BIMPORTS InlineDefs, IODefs, RealDefs, WF =l4800d2998e6BEGIN OPEN InlineDefs, IODefs, RealDefs, WF;l3658d2998FloatNum: TYPE = RECORD[m2: CARDINAL, sign:[0..1], exp:[0..400B), m1:[0..200B)];l3658d2998place: ARRAY [0..6) OF CARDINAL;l3658d2998pplace: POINTER TO UNSPECIFIED _ LOOPHOLE[720B];l3658d2998a, b, x: REAL;l3658d2998q: LONG INTEGER;l3658d2998c: CHARACTER;l3658d2998uLocMulT: CARDINAL = 446B;l3658d2998uLocDivT: CARDINAL = 447B;l3658d2998imode: BOOLEAN _ TRUE;l3658d2998binmode: BOOLEAN _ FALSE;l3658d2998errmsg: ARRAY FloatingError OF STRING _["noError","FixExponentOverflow","ExponentOverflow","DivideBy0"];l3658d2998BEGIN-- These two routines are for looking at the 16 bit integer multiply and divide parts of the float microcode.  The appropriate access sections follow:l3680d2998j-- %1,1777,446,ucMulT;				Multiply Test-- %1,1777,447,ucDivT;				Subtract Test-- ;  This routine is MulT-- -- !7,10,MulRet,MulRet1,MulRet2,MulRet3,MulRet4;-- ucMulT: L_stk0,TASK;-- 	Arg0_L;-- 	L_stk1,TASK;-- 	Arg1_L;-- 	L_stk2,TASK;-- 	Arg2_L;-- 	L_4,:MUL;-- MulRet4: L_Arg0,TASK;-- 	stk0_L;-- 	L_Arg1,TASK;-- 	stk1_L,:ret;-- -- ;  This routine is DivT-- -- !7,10,DivRet,DivRet1,DivRet2,DivRet3;-- ucDivT: L_stk0,TASK;-- 	Arg0_L;-- 	L_stk1,TASK;-- 	Arg1_L;-- 	L_stk2,TASK;-- 	Arg2_L;-- 	L_3,:DIV;-- -- DivRet3: L_Arg0,TASK;-- 	stk0_L;-- 	L_Arg1,TASK;-- 	stk1_L,:ret;(635)WFpR: PROCEDURE [p: UNSPECIFIED, form:STRING, wp: PROCEDURE[CHARACTER]] =l4256d2998(1792)\b4BBEGINl4268fp: POINTER TO REAL _ p;l4268WriteNum[fp^];l4268END;l4268(635)(1792)zMulT: PROCEDURE [a,b,c: CARDINAL] RETURNS [d,e: CARDINAL] =\b5BMACHINE CODE BEGINl4268Mopcodes.zLIW, uLocMulT/256, uLocMulT MOD 256;l4268Mopcodes.zJRAM;l4268END;l4268(635)(1792)zDivT: PROCEDURE [a,b,c: CARDINAL] RETURNS [d,e: CARDINAL] =\b5BMACHINE CODE BEGINl4268Mopcodes.zLIW, uLocDivT/256, uLocDivT MOD 256;l4268Mopcodes.zJRAM;l4268END;l4268(635)WriteNum: PROCEDURE [x: REAL] =l3658d2998e12(1792)\b8BBEGINl4928d4268mf: FloatNum;l4928d4268IF NOT imode THEN WriteFloat[x];l4714d4268WF0["  "];l4714d4268mf _ LOOPHOLE[x, FloatNum];l4714d4268-- WF4["  sgn: %1d,  exp: %3bB,  m1: %3bB,  m2: %6bB*n",mf.sign, mf.exp, mf.m1+200B, mf.m2];l4714d4268WF0[" em: "];l4714d4268PrintReal[x];l4714d4268-- WF4["  S1: %6bB,  E1: %6bB,  M1: %6bB,  N1: %6bB*n",place[0], place[1], place[2], place[3]];l4714d4268END;l4928d4268PrintReal: PROCEDURE [v: REAL] =l3658d2998e12\b9BBEGINl4928d4268man: LongNumber;l4714d4268sign: BOOLEAN;l4714d4268exp: INTEGER;l4714d4268mf: FloatNum;l4928d4268mf _ LOOPHOLE[v, FloatNum];l4714d4268sign _ mf.sign=1;l4714d4268IF sign THENl4714d4268BEGINl5984d5538man.lc _ LOOPHOLE[v,LONG CARDINAL];l5984d5538man.li _ 0-man.li;l5984d5538v _ LOOPHOLE[man.lc, REAL];l5984d5538mf _ LOOPHOLE[v, FloatNum];l5984d5538END;l5984d5538man.lowbits _ mf.m2;l4714d4268man.highbits _ mf.m1+0200B;l4714d4268IF mf.exp=0 THENl4714d4268BEGINl5984d5538sign _ FALSE;l5984d5538exp _ 0;l5984d5538man.lc_0;l5984d5538ENDl5984d5538ELSE exp _ mf.exp-128;l4714d4268WF0[IF sign THEN "- " ELSE "  "];l4714d4268-- mantissa should print as 8 octal digitsl4714d4268WF2["e%4d  m.%lb", exp, @man.lc];l4714d4268END;l4928d4268SqRt: PUBLIC PROCEDURE [x: REAL] RETURNS [REAL] =e12\b4BBEGINl4268magic: CARDINAL _ 200B-22;l4268t1,t2,t3,t4,y,x1,epsilon: REAL;l4268fl: FloatNum;l4268l4268IF x <= 0 THEN RETURN[0];l4268l4268WF1["arg: %R*n",@x]; l4268fl _ LOOPHOLE[x,FloatNum];l4268fl.exp _ (fl.exp - 200B)/2 +200B;l4268y _ LOOPHOLE[fl,REAL];	--initial guess = half original exponentl4268fl _ [sign: 0,exp: magic,m1: 0,m2: 0];l4268epsilon _ LOOPHOLE[fl,REAL];l4268l4268WF1["epsilon: %R*n",@epsilon]; l4268WF1["init guess: %R*n",@y]; l4268l4268DOl4268x1 _ y*y;l4268WF1["guess,sq: %R*n",@x1]; l4268t1 _ x1-x;l4268WF1["error: %R*n",@t1]; l4268t2 _ 2*y;l4268WF1["guessX2: %R*n",@t2]; l4268t3 _ (t1/t2);	--slope of the curve here is 1/2l4268WF1["correction: %R*n",@t3]; l4268y_y-t3;	--slope of the curve here is 1/2l4268WF1["new guess: %R*n",@y]; l4268t4 _ t1/x;l4268WF1["pct err: %R*n",@t4]; l4268IF ABS[t4] <= ABS[epsilon] THEN EXIT;l4268ENDLOOP;l4268l4268RETURN[y];l4268END;l4268(635)ReadReal: PROCEDURE RETURNS [v: REAL] =l3658d2998e12(1792)\b8BBEGINl4928d4268s: STRING _ [50];l4714d4268eok, esign, sign: BOOLEAN;l4714d4268exp: INTEGER;l4714d4268i: CARDINAL;l4714d4268man: LongNumber;l4714d4268mf: FloatNum;l4928d4268DOl4928d4268eok _ esign _ sign _ FALSE;l6198d5538s.length_0;l6198d5538exp _ 0;l6198d5538man.lc _ 0;l6198d5538ReadID[s];l6198d5538i _ 0;l6198d5538WHILE i<s.length DOl6198d5538SELECT s[i] FROMl7468d6808'- => sign_TRUE;l8738d8078'+ => sign_FALSE;l8738d8078'e => BEGINl8738d8078WHILE i<s.length DOl10008d9348SELECT s[i] FROMl11278d10618'- => BEGIN esign _ eok _ TRUE; END;l12548d11888'+ => BEGIN esign _ FALSE; eok _ TRUE; END;l12548d11888IN ['0..'9] => BEGINl12548d11888exp _ exp*10+(s[i]-'0);l13818d13158eok _ TRUE;l13818d13158END;l13818d13158ENDCASE => BEGINl12548d11888IF eok THEN EXIT;l13818d13158END;l13818d13158i _ i+1;l11278d10618ENDLOOP;l11278d10618END;l10008d9348IN ['0..'7] => man.lc _ man.lc*10B + (s[i]-'0);l8738d8078ENDCASE;l8738d8078i _ i+1;l7468d6808ENDLOOP;l7468d6808IF (exp NOT IN[0..127]) OR (man.lc#0 AND BITAND[man.highbits,200B]=0) THEN l6198d5538BEGINl7468d6808WF0["*n[-]e[-]Exponent(10).Mantissa(8 octal digits)*n"];l7468d6808ENDl7468d6808ELSE EXIT;l6198d5538ENDLOOP;l6198d5538IF man.lc=0 THEN RETURN[0];l4928d4268IF esign THEN exp_0-exp;l4928d4268mf.exp _ BITAND[exp+128,377B];l4928d4268mf.m1 _ BITAND[man.highbits,177B];l4928d4268mf.m2 _ man.lowbits;l4928d4268IF sign THENl4928d4268BEGINl6198d5538man.lc _ LOOPHOLE[mf,LONG CARDINAL];l6198d5538man.li _ 0-man.li;l6198d5538v _ LOOPHOLE[man.lc,REAL];l6198d5538ENDl6198d5538ELSE v _ LOOPHOLE[mf,REAL];l4928d4268WF0["*n val= "];l4928d4268PrintReal[v];l4928d4268WF0["*n"];l4928d4268END;l4928d4268ReadLongDecimal: PROCEDURE RETURNS[z: LONG INTEGER] =l3658d2998e12\b15BBEGINl4928d4268ch: CHARACTER;l4928d4268sign: BOOLEAN _ FALSE;l4928d4268z _ 0;l4928d4268DOl4928d4268ch _ ReadChar[];l6198d5538WriteChar[ch];l6198d5538SELECT ch FROMl6198d5538'- => sign _ TRUE;l7468d6808'+ => sign _ FALSE;l7468d6808IN ['0..'9] =>  z _ (z*10)+(ch-'0);l7468d6808ENDCASE => EXIT;l7468d6808ENDLOOP;l6198d5538IF sign THEN RETURN[0-z];l4928d4268END;l4928d4268ReadArgs: PROCEDURE RETURNS[a, b: REAL] =l3658d2998e12\b8BBEGINl4928d4268WF0["  a:  "];l4928d4268IF binmode THEN a _ ReadReal[]l4928d4268ELSE IF imode THEN a _ ReadDecimal[] ELSE a _ ReadFloat[];l4928d4268WF0["  b:  "];l4928d4268IF binmode THEN b _ ReadReal[]l4928d4268ELSE IF imode THEN b _ ReadDecimal[] ELSE b _ ReadFloat[];l4928d4268END;l4928d4268-- Mainline codel3658d2998e12\3b13B-- This pplace stuff is for a version of the float microcode which stored the internal representation in 4 words pointed to by location 720B.  The appropriate code fragment follows:l3680d2998j--RePack:--	T_DASTART;  this code for debugging--	L_300+T;--	MAR_LastL;  save unpacked arg according to pointer in 720--	NOP;--	L_MD,TASK;--	Temp_L;--	MAR_Temp;--	L_Temp+1;--	Temp_L,TASK;--	MD_S1;--	MAR_Temp;--	L_Temp+1;--	Temp_L,TASK;--	MD_E1;--	MAR_Temp;--	L_Temp+1;--	Temp_L,TASK;--	MD_M1;--	MAR_Temp;--	L_Temp+1;--	Temp_L,TASK;--	MD_N1;l3680d2998j-- pplace^ _ BASE[place];SetCode[ 'R, WFpR];SetCode[ 'F, WFWriteFloat];WF0["*nFunction (add, imode, subtract, multiply, divide, fix, Float)*n"];WF0["if imode is ON, ReadFloat and WriteFloat won't be called*n"];DO ENABLE FloatingPointError =>e12BEGINl4268WF1["*n%s*n",errmsg[f]];l4268-- CONTINUE;l4268RESUME;l4268END;l4268place[0] _ place[1] _ place[2] _ place[3] _ 52525B;l4268WF0["uct: "];l4268c _ IODefs.ReadChar[];l4268SELECT c FROMl4268'a =>l5538BEGINl6808WF0["Add:  "];l6808[a,b] _ ReadArgs[];l6808x _ a + b;l6808WF1["  Sum = %R*n",@x];l6808END;l6808'c =>l5538BEGINl6808WF0["Compare:  "];l6808[a,b] _ ReadArgs[];l6808IF a<b THEN WF0[" a less than b*n"];l6808IF a=b THEN WF0[" a equals b*n"];l6808IF a>b THEN WF0[" a greater than b*n"];l6808END;l6808'b =>l5538BEGINl6808WF0["Binary Mode "];l6808binmode _ NOT binmode;l6808IF binmode THEN WF0["ON*n"] ELSE WF0["OFF*n"];l6808END;l6808'i =>l5538BEGINl6808WF0["Integer Mode "];l6808imode _ NOT imode;l6808IF imode THEN WF0["ON*n"] ELSE WF0["OFF*n"];l6808END;l6808's =>l5538BEGINl6808WF0["Subtract:  "];l6808[a,b] _ ReadArgs[];l6808x _ a - b;l6808WF1["  Difference = %R*n",@x];l6808END;l6808'M => IF FALSE THEN  -- commented outl5538BEGINl6808i,j,k,x,y: CARDINAL;l6808z: LONG CARDINAL;l6808WF0["Fixed Multiply (A+(B*C)):  "];l6808WF0["A: "];l6808i _ ReadDecimal[];l6808WF0["B: "];l6808j _ ReadDecimal[];l6808WF0["C: "];l6808k _ ReadDecimal[];l6808[x,y] _ zMulT[i,j,k];l6808z _ (x*65536)+y;l6808WF1[" Result = %ld*n",@z];l6808END;l6808'D => IF FALSE THEN  -- commented outl5538BEGINl6808i,j,k,x,y: CARDINAL;l6808z: LONG CARDINAL;l6808WF0["Fixed Divide (A/B):  "];l6808WF0[" A: "];l6808z _ ReadLongDecimal[];l6808WF1["(= %ld)",@z];l6808WF0[" B: "];l6808i _ ReadDecimal[];l6808j _ HighHalf[z];l6808k _ LowHalf[z];l6808WF0["  Product =  "];l6808[x,y] _ zDivT[j,k,i];l6808WF2[" Quotient = %d, remainder = %d*n", y, x];l6808END;l6808'm =>l5538BEGINl6808WF0["Multiply:  "];l6808[a,b] _ ReadArgs[];l6808x _ a * b;l6808WF1["  Product =  %R*n",@x];l6808END;l6808'd =>l5538BEGINl6808WF0["Divide:  "];l6808[a,b] _ ReadArgs[];l6808x _ a / b;l6808WF1["  Quotient =  %R*n",@x];l6808END;l6808'f =>l5538BEGINl6808WF0["Fix:  "];l6808x _ IF imode THEN ReadDecimal[] ELSE ReadFloat[];l6808q _ Fix[x];l6808WF2["  Fix: %iB Float:  %R*n", @q,@x];l6808END;l6808'F =>l5538BEGINl6808WF0["Float: (16 bit integer) "];l6808q _ ReadLongDecimal[];l6808x _ q;  -- floatl6808WF2["  Fix: %ld, Float:  %R*n", @q, @x];l6808END;l6808'S =>l5538BEGINl6808WF0["SqRt:  "];l6808a _ IF binmode THEN ReadReal[] ELSE ReadFloat[];l6808x _ SqRt[a];l6808WriteNum[x];l6808END;l6808ENDCASE;l5538ENDLOOP;l4268END;END.l3658d2998e12