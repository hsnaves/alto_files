-- FloatTimeTest.mesa to measure speed of number stuffl3008(1792)-- Copywrite Xerox Corporation 1980z18591l3712d2998j-- Originally by J. Maleson-- Modified by L. Stewart May 27, 1980  1:00 PM-- added assignment, comparisionl3008DIRECTORYe12IODefs: FROM "IODefs",l4928d4268Mopcodes: FROM "Mopcodes",l4928d4268SDDefs: FROM "SDDefs",l4928d4268RealDefs: FROM "RealDefs",l4704d4268WF: FROM "WF";l4928d4268FloatTimeTest: PROGRAM IMPORTS IODefs, RealDefs, WF =l3658d2998e12\b13BBEGIN OPEN IODefs, RealDefs, WF;sNullProc: CARDINAL = 140B; -- (hopefully) empty SD slotr,s,t: REAL;q: LONG INTEGER;RTC: POINTER TO CARDINAL = LOOPHOLE[430B];Disp: POINTER TO CARDINAL = LOOPHOLE[420B];odcb, card: CARDINAL;int: INTEGER;i: CARDINAL;numTests: CARDINAL;loopTime,assgnTime,nullSDTime,addTime: CARDINAL;subTime,mulTime,divTime,compTime,fixTime,floatTime: CARDINAL;startTime,endTime: CARDINAL;equal: BOOLEAN;NullProc: PROCEDURE[a,b: REAL] RETURNS [REAL] =BEGINl4268RETURN[a];l4268END;l4268zNullProc: PROCEDURE[a,b: REAL] RETURNS [REAL] =MACHINE CODE BEGINl4268Mopcodes.zKFCB, sNullProc;l4268END;l4268SDDefs.SD[sNullProc] _ NullProc;DOWF0["Number of tests? (decimal): "];l4268numTests _ ReadDecimal[];l4268WF0["*nArguments (float) ?  x: "];l4268r _ ReadFloat[];l4268WF0[" y: "];l4268s _ ReadFloat[];l4268WF0["*n"];l4268l4268odcb _ Disp^;l4268Disp^ _ 0;l4268startTime _ RTC^;l4268FOR i IN [0..numTests) DO ENDLOOP;l4268endTime _ RTC^;l4268Disp^ _ odcb;l4268loopTime _ endTime-startTime;l4268WF1["empty loop:  %d*n",(loopTime*39)];l4268l4268odcb _ Disp^;l4268Disp^ _ 0;l4268startTime _ RTC^;l4268FOR i IN [0..numTests) DO t _ r; ENDLOOP;l4268endTime _ RTC^;l4268Disp^ _ odcb;l4268assgnTime _ endTime-startTime;l4268WF1["assignment:  %d*n",(assgnTime*39)];l4268l4268odcb _ Disp^;l4268Disp^ _ 0;l4268startTime _ RTC^;l4268FOR i IN [0..numTests) DO t _ zNullProc[r,s]; ENDLOOP;l4268endTime _ RTC^;l4268Disp^ _ odcb;l4268nullSDTime _ endTime-startTime;l4268WF1["null SD:  %d*n",(nullSDTime*39)];l4268l4268odcb _ Disp^;l4268Disp^ _ 0;l4268startTime _ RTC^;l4268FOR i IN [0..numTests) DO t _ r + s; ENDLOOP;l4268endTime _ RTC^;l4268Disp^ _ odcb;l4268addTime _ endTime - startTime;l4268WF1["add: %d*n",(addTime*39)];l4268l4268odcb _ Disp^;l4268Disp^ _ 0;l4268startTime _ RTC^;l4268FOR i IN [0..numTests) DO t _ r - s; ENDLOOP;l4268endTime _ RTC^;l4268Disp^ _ odcb;l4268subTime _ endTime - startTime;l4268WF1["sub:  %d*n",(subTime*39)];l4268l4268odcb _ Disp^;l4268Disp^ _ 0;l4268startTime _ RTC^;l4268FOR i IN [0..numTests) DO t _ r * s; ENDLOOP;l4268endTime _ RTC^;l4268Disp^ _ odcb;l4268mulTime _ endTime - startTime;l4268WF1["mul:  %d*n",(mulTime*39)];l4268l4268odcb _ Disp^;l4268Disp^ _ 0;l4268startTime _ RTC^;l4268FOR i IN [0..numTests) DO t _ r / s; ENDLOOP;l4268endTime _ RTC^;l4268Disp^ _ odcb;l4268divTime _ endTime - startTime;l4268WF1["div:  %d*n",(divTime*39)];l4268l4268odcb _ Disp^;l4268Disp^ _ 0;l4268startTime _ RTC^;l4268FOR i IN [0..numTests) DO equal _ r=s; ENDLOOP;l4268endTime _ RTC^;l4268Disp^ _ odcb;l4268compTime _ endTime - startTime;l4268WF1["comp: %d*n",(compTime*39)];l4268l4268odcb _ Disp^;l4268Disp^ _ 0;l4268startTime _ RTC^;l4268FOR i IN [0..numTests) DO q _ Fix[r]; ENDLOOP;l4268endTime _ RTC^;l4268Disp^ _ odcb;l4268fixTime _ endTime - startTime;l4268WF1["fix:  %d*n",(fixTime*39)];l4268l4268odcb _ Disp^;l4268Disp^ _ 0;l4268startTime _ RTC^;l4268FOR i IN [0..numTests) DO int _ FixI[r]; ENDLOOP;l4268endTime _ RTC^;l4268Disp^ _ odcb;l4268fixTime _ endTime - startTime;l4268WF1["fixI:  %d*n",(fixTime*39)];l4268l4268odcb _ Disp^;l4268Disp^ _ 0;l4268startTime _ RTC^;l4268FOR i IN [0..numTests) DO card _ FixC[r]; ENDLOOP;l4268endTime _ RTC^;l4268Disp^ _ odcb;l4268fixTime _ endTime - startTime;l4268WF1["fixC:  %d*n",(fixTime*39)];l4268l4268q _ Fix[r];l4268odcb _ Disp^;l4268Disp^ _ 0;l4268startTime _ RTC^;l4268FOR i IN [0..numTests) DO t _ q; ENDLOOP;l4268endTime _ RTC^;l4268Disp^ _ odcb;l4268floatTime _ endTime - startTime;l4268WF1["float: %d*n",(floatTime*39)];l4268l4268[]_ReadChar[];l4268ENDLOOP;l4268END.(635)