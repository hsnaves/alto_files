-- FloatFixTest.mesal4128d2998(1792)\3b17B-- Copywrite Xerox Corporation 1980z18591l3712d2998j-- Program to check out new Floating arithmeticl4128d2998-- Last Modified: LStewart May 27, 1980  12:06 PMl4128d2998DIRECTORYe12IODefs: FROM "IODefs",l4704d4268RealDefs: FROM "RealDefs",l4704d4268WF: FROM "WF";l4704d4268FloatFixTest: PROGRAMl3658d2998e12\b12BIMPORTS RealDefs, IODefs, WF =l4800d2998e6BEGIN OPEN RealDefs, IODefs, WF;l3658d2998x: REAL;l3658d2998i: INTEGER;l3658d2998c: CARDINAL;l3658d2998q: LONG INTEGER;l3658d2998ch: CHARACTER;l3658d2998errmsg: ARRAY FloatingError OF STRING _["noError","FixRangeOverflow","ExponentOverflow","DivideBy0"];l3658d2998BEGINMainP: PROCEDURE =e12\b5BBEGINl4268SELECT ch FROMl4268'c =>l5538BEGINl6808WF0["Fix to Cardinal: "];l6808x _ ReadFloat[];l6808c _ FixC[x];l6808WF2["*nFix: %u Float:  %F*n", c,@x];l6808END;l6808'i =>l5538BEGINl6808WF0["Fix to Integer: "];l6808x _ ReadFloat[];l6808i _ FixI[x];l6808WF2["*nFix: %d Float:  %F*n", i,@x];l6808END;l6808'f =>l5538BEGINl6808WF0["Fix to LongInteger:  "];l6808x _ ReadFloat[];l6808q _ Fix[x];l6808WF2["*nFix: %lbB Float:  %F*n", @q,@x];l6808END;l6808ENDCASE;l5538END;l4268(635)e12-- Mainline codel3658d2998e12(1792)\3b13BSetCode[ 'F, WFWriteFloat];WF0["*nFunction: Fix to Integer, Cardinal. LongInteger*n"];DO ENABLE FloatingPointError =>e12BEGINl4268WF1["*n%s*n",errmsg[f]];l4268RESUME;l4268END;l4268WF0[": "];l4268ch _ IODefs.ReadChar[];l4268MainP[];l4268ENDLOOP;l4268END;END.  --of FloatFixTestl3658d2998e12\11b12B