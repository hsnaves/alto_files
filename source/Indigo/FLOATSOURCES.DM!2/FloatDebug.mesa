-- FloatDebug.mesal4128d2998(1792)\f7 3b15B-- Copywrite Xerox Corporation 1980z18591l3712d2998j\f7-- Conversion of REALs to and from Strings for the debuggerl4128d2998\f7-- This is a cut down version of FloatIOl4128d2998\f7-- Last Modified: LStewart September 12, 1979  4:40 PMl4128d2998\f7DIRECTORYe12\f7DebugRealDefs: FROM "DebugRealDefs",l4704d4268\f7InlineDefs: FROM "InlineDefs",l4704d4268\f7IODefs: FROM "IODefs",l4704d4268\f7RealDefs: FROM "RealDefs",l4704d4268\f7StringDefs: FROM "StringDefs";l4704d4268\f7\f7FloatDebug: PROGRAMl3712d2998\f7b10BIMPORTS InlineDefs, RealDefs, StringDefsl3712d2998\f7EXPORTS DebugRealDefs =l3712d2998\f7BEGIN OPEN InlineDefs, IODefs, RealDefs, StringDefs;\f7Zero: REAL _ 0;\f7One: REAL _ 1;l3658d2998\f7Ten: REAL _ 10;\f7ULim: REAL _ 999999;\f7LLim: REAL _ Ten/10000;\f7FloatNum: TYPE = RECORD [m2: CARDINAL, sign:[0..1], exp:[0..400B), m1:[0..200B)];l3712d2998\f7\f7AppendRealNumber: PUBLIC PROCEDURE [s: STRING, r: REAL] =l3658d2998e12\f7b16BBEGINl4928d4268\f7CharToString: PROCEDURE [ c: CHARACTER ] =l4928d4268\f7b12BBEGINl6198d5538\f7StringDefs.AppendChar[s, c];l6198d5538\f7END;l6198d5538\f7AppendFloatTo[R: r, pProc: CharToString, lj: FALSE, lc: 0, rc: 0, EFormat: FALSE];l4928d4268\f7END;l4928d4268\f7AppendFloatTo: PROCEDURE [R: REAL, pProc: PROCEDURE [CHARACTER], lj: BOOLEAN, lc: CARDINAL, rc: CARDINAL, EFormat: BOOLEAN] =l3658d2998e12\f7b13BBEGIN\f7Q,M,S: REAL;\f7pdl: ARRAY [0..40] OF [0..10);\f7cols, sindex: CARDINAL;\f7fexp, k, U: INTEGER;\f7fman, iPart: LONG INTEGER;\f7expt: INTEGER _ 0;\f7NotFill, LastWasDot, Digits, DecimalPt: BOOLEAN _ FALSE;\f7outS: STRING _ [20];\f7fracS: STRING _ [20];\f7ExptMark: PROCEDURE =e12(635)\f7b8BBEGINl4268\f7IF EFormat AND ~DecimalPt THENl4268(1792)\f7BEGINl5538\f7expt _ k;l5538\f7DecimalPt_TRUE;l5538\f7END;l5538\f7END;l4268(635)\f7Output: PROCEDURE [c: CHARACTER] =e12\f7b6BBEGINl4268\f7AppendChar[IF DecimalPt THEN fracS ELSE outS, c];l4268(1792)\f7END;l4268(635)\f7LeftFill: PROCEDURE =e12\f7b8BBEGINl4268\f7IF NOT EFormat THEN THROUGH [1..k] DO Output['0]; ENDLOOP;l4268(1792)\f7END;l4268(635)\f7FracOut: PROCEDURE [i: INTEGER] =e12\f7b7BBEGINl4268\f7IF i#0 THEN NotFill _ TRUE;l4268(1792)\f7IF NotFill THENl4268\f7BEGINl5538\f7Output['0+i];l5538\f7ExptMark[];l5538\f7ENDl5538\f7ELSE BEGIN IF NOT EFormat THEN Output['0]; END;l4268\f7END;l4268(635)\f7PrintIt: PROCEDURE =e12(1792)\f7b7BBEGINl4268\f7--  Now think about printing the stuff out.  We have a string of integer and possible leading '- in outS, a string of fraction digits in fracS, and possible decimal point and exponent.l4918d4268j\f7cols _ outS.length;l4268\f7IF EFormat THEN cols _ cols+6;l4268\f7IF EFormat AND rc>0 THEN rc _ MAX[rc, 1];l4268\f7IF lc>0 AND cols>lc THEN  -- Field overflow.l4268\f7BEGINl5538\f7pProc[' ];l5538\f7THROUGH [1..lc) DO pProc['*]; ENDLOOP;l5538\f7RETURN;l5538\f7END;l5538\f7-- IF EFormat, we already reserved space for the '. and one fraction digit.  If NOT EFormat, we had not reserved space for the '..  I. e. at this point, cols has the required space, we now adjust it to find the allowable space for the fraction digits.l4918d4268j\f7 166i8IIF EFormat THEN cols _ cols-1 ELSE cols _ cols+1;l4268\f7IF rc>0 THEN fracS.length _ MIN[rc, fracS.length];l4268\f7IF lc>0 THEN fracS.length _ MIN[fracS.length, lc-cols];l4268\f7-- Now compute the new required space...l4268\f7cols _ outS.length;l4268\f7IF EFormat THEN cols _ cols+5+MAX[1, fracS.length]l4268\f7ELSE BEGIN IF fracS.length>0 THEN cols _ cols+fracS.length+1; END;l4268\f7cols _ lc-cols;l4268\f7IF lc>0 AND NOT lj THEN THROUGH [0..cols) DO pProc[' ]; ENDLOOP;l4896d4268\f7-- Print leading stuff.l4268\f7FOR sindex IN [0..outS.length) DO pProc[outS[sindex]]; ENDLOOP;l4268\f7-- Print fraction, if there.l4268\f7IF fracS.length>0 THENl4268\f7BEGINl5538\f7pProc['.];l5538\f7FOR sindex IN [0..fracS.length) DO pProc[fracS[sindex]]; ENDLOOP;l5538\f7END;l5538\f7-- Print exponent.l4268\f7IF EFormat THEN l4268\f7BEGINl5538\f7-- EFormat requires at least x.0e+yy.l5538\f7IF fracS.length=0 THENl5538\f7BEGIN pProc['.]; pProc['0]; END;l6808\f7pProc['e];l5538\f7IF expt<0 THEN BEGIN pProc['-]; expt _ -expt; ENDl5538\f7ELSE pProc['+];l5538\f7pProc['0+(expt/10)];l5538\f7pProc['0+(expt MOD 10)];l5538\f7END;l5538\f7IF lc>0 AND lj THEN THROUGH [0..cols) DO pProc[' ]; ENDLOOP;l4268\f7END;l4268\f7\f7IF R=Zero THEN BEGIN Output['0]; PrintIt[]; RETURN; END;\f7IF R<Zero THEN\f7BEGINl4268\f7Output['-];l4268\f7R _ -R;l4268\f7END;l4268\f7\f7-- Force E Format.l3648d2998e6\f7IF R NOT IN [LLim..ULim] THEN BEGIN EFormat_TRUE; END;\f7\f7-- Establish the termination condition mask. The value of mask is 1/2 the value of the least significant bit of the mantissa of R.l3648d2998e6\f7[fexp, fman] _ Unpack[R];l3648d2998\f7M _ Scale[1, fexp-1];l3648d2998\f7k _ 0;\f7Q _ R;\f7S _ 1;\f7-- Prescale into the range of LONG INTEGER.l3648d2998e6\f7WHILE Q>=LAST[LONG INTEGER] DO\f7pdl[k]_0;l4268\f7k _ k+1;l4268\f7Q _ Q/Ten;l4268\f7S _ S*Ten;l4268\f7ENDLOOP;l4268\f7\f7-- Accumulate the rest of the digits of integer representation.l3648d2998e6\f7iPart _ Fix[Q];\f7WHILE iPart>0 DO\f7pdl[k]_InlineDefs.LowHalf[iPart MOD 10];l4268\f7iPart _ iPart/10;l4268\f7k _ k+1;l4268\f7S _ S*Ten;l4268\f7ENDLOOP;l4268\f7\f7Q _ R;\f7WHILE k>0 DO  -- always at least one thing on pdl\f7k _ k-1;l4268\f7S _ S/Ten;l4268\f7U _ pdl[k];l4268\f7Q _ Q - U*S;l4268\f7IF Q NOT IN [M..S-M] THEN GO TO MaskExit;l4268\f7Output['0+U];l4268\f7Digits _ TRUE;l4268\f7ExptMark[];l4268\f7REPEATl4268\f7MaskExit =>l4268\f7BEGINl5538\f7IF 2*Q <=S THEN Output['0+U]l5538\f7ELSE Output['0+U+1];l5538\f7Digits _ TRUE;l5538\f7ExptMark[];l5538\f7LeftFill[];l5538\f7END;l5538\f7ENDLOOP;l4268\f7\f7IF NOT EFormat THEN\f7BEGINl4268\f7IF NOT Digits THEN Output['0];l4268\f7DecimalPt _ TRUE;l4268\f7END;l4268\f7\f7--now, R has fractional part and S=1\f7-- Output some fraction digits if there were any.  That we will output any fraction digits means that 1) the integer part has been printed exactly, and 2) the Fix below will not trap.l3648d2998\f7IF fexp<0 THEN\f7BEGINl4268\f7k _ 0;l4268\f7R _ R-Fix[R];  -- Get fraction part.l4268\f7IF R#0 THEN BEGINl4268\f7M _ Scale[1, fexp-1];l5538\f7DOl5538\f7k _ k-1;l6808\f7R _ R*Ten;l6808\f7U _ InlineDefs.LowHalf[Fix[R]];l6808\f7R _ R-U;l6808\f7M _ M*Ten;l6808\f7IF R NOT IN [M..1-M] THEN EXIT;l6808\f7FracOut[U];l6808\f7ENDLOOP;l6808\f7IF 2*R<=1 THEN FracOut[U]l5538\f7ELSE FracOut[U+1];l5538\f7END;l5538\f7END;l4268\f7\f7PrintIt[];l3648d2998j\f7\f7END;  --end of WriteFloat(635)\f7-- Take apart a REAL so that m*2^e = rl3648d2998e12\f7Unpack: PROCEDURE [r: REAL] RETURNS [e: INTEGER, m: LONG INTEGER] =l3648d2998e12\f7b6BBEGINl4268\f7minus: BOOLEAN _ r<0;l4268\f7w: LongNumber;l4268\f7IF minus THEN r _ -r;l4268\f7w _ LOOPHOLE[r, LongNumber];l4268\f7e _ BITAND[377B, BITSHIFT[w.highbits, -7]] - 128 - 24;l4268\f7w.highbits _ BITOR[200B, BITAND[177B, w.highbits]];l4268\f7m _ IF minus THEN -w.li ELSE w.li;l4268\f7END;l4268\f7-- Multiply a REAL by a power of 2l3648d2998e12\f7Scale: PROCEDURE [r: REAL, se: INTEGER] RETURNS [REAL] =l3648d2998e12\f7b5BBEGINl4268\f7f: FloatNum;l4268\f7minus: BOOLEAN _ r<0;l4268\f7exp: INTEGER;l4268\f7IF minus THEN r _ -r;l4268\f7f _ LOOPHOLE[r, FloatNum];l4268\f7exp _ f.exp+se;l4268\f7IF exp<=0 THEN RETURN[LOOPHOLE[FloatNum[0,0,1,0], REAL]];l4268\f7IF exp>377B THENl4268\f7BEGINl5538\f7IF minus THEN RETURN[LOOPHOLE[20000000001B, REAL]]l5538\f7ELSE RETURN[LOOPHOLE[17777777777B, REAL]];l5538\f7END;l5538\f7f.exp _ exp;l4268\f7r _ LOOPHOLE[f, REAL];l4268\f7IF minus THEN r _ -r;l4268\f7RETURN[r];l4268\f7END;l4268\f7-- Return integer part of a REAL Modulo somethingl3648d2998e12\f7FMod: PROCEDURE [r: REAL, m: LONG INTEGER] RETURNS [LONG INTEGER] =l3648d2998e12\f7b4BBEGINl4268\f7int: LONG INTEGER _ Fix[r ! FloatingPointError => GOTO GiveUp];l4268\f7RETURN[int MOD m]l4268\f7EXITSl4268\f7GiveUp => RETURN[0];l4268\f7END;l4268\f7-- Return fraction part of a REALl3648d2998e12\f7Fraction: PROCEDURE [r: REAL] RETURNS [REAL] =l3648d2998e12\f7b8BBEGINl4268\f7t: LONG INTEGER _ Fix[r ! FloatingPointError => GOTO GiveUp];l4268\f7RETURN[r-t];l4268\f7EXITSl4268\f7GiveUp => RETURN[0];l4268\f7END;l4268\f7StringToRealNumber: PUBLIC PROCEDURE [ s: STRING ] RETURNS [REAL] =l3658d2998e12(1792)\f7b18BBEGINl4928d4268\f7stringIndex: CARDINAL _ 0;l4928d4268\f7CharProcString: PROCEDURE RETURNS[ CHARACTER ] =l4928d4268\f7b14BBEGINl6198d5538\f7IF stringIndex=s.length THEN RETURN [IODefs.DEL]l6198d5538\f7ELSEl6198d5538\f7BEGINl7468d6808\f7ch: CHARACTER _ s[stringIndex];l7468d6808\f7stringIndex _ stringIndex+1;l7468d6808\f7RETURN[ch];l7468d6808\f7END;l7468d6808\f7END;l6198d5538\f7RETURN [StreamToFloat[ CharProcString ]];l4928d4268\f7END;l4928d4268\f7StreamToFloat: PRIVATE PROCEDURE [charProc: PROCEDURE RETURNS [ CHARACTER ]] RETURNS [REAL] =l3658d2998e12\f7b13BBEGIN ENABLE FloatingPointError => RESUME;l4928d4268\f7InsideProc: PROCEDURE RETURNS [REAL] =l4928d4268\f7b10BBEGINl4928d4268\f7expPartV: INTEGER _ 0;l4928d4268\f7val, intVal, fracVal, rcVal, expVal: REAL _ Zero;l4928d4268\f7fracExp: REAL _ One;l4928d4268\f7minus, expMinus: BOOLEAN _ FALSE;l4928d4268\f7mode: {firstSymbol, intPart, fracPart, firstExpSymbol, expPart} _ firstSymbol;l4928d4268\f7cVal: INTEGER;l4928d4268\f7c: CHARACTER;l4928d4268\f7DOl4928d4268\f7c _ charProc[];l6198d5538\f7cVal _ LOOPHOLE[c-'0, INTEGER];l6198d5538\f7rcVal _ cVal;l6198d5538\f7SELECT c FROMl6198d5538\f7' , CR, TAB => SELECT mode FROMl7468d6808\f7firstSymbol => NULL;l8738d8078\f7ENDCASE => EXIT;l8738d8078\f7'+ => SELECT mode FROMl7468d6808\f7firstSymbol => mode _ intPart;l8738d8078\f7firstExpSymbol => mode _ expPart;l8738d8078\f7ENDCASE => EXIT;l8738d8078\f7'- => SELECT mode FROMl7468d6808\f7firstSymbol =>l8738d8078\f7BEGIN minus _ TRUE; mode _ intPart; END;l10008d9348\f7firstExpSymbol =>l8738d8078\f7BEGIN expMinus _ TRUE; mode _ expPart; END;l10008d9348\f7ENDCASE => EXIT;l8738d8078\f7'. => SELECT mode FROMl7468d6808\f7firstSymbol, intPart => mode _ fracPart;l8738d8078\f7ENDCASE => EXIT;l8738d8078\f7'D, 'E, 'd, 'e => SELECT mode FROMl7468d6808\f7intPart, fracPart => mode _ firstExpSymbol;l8738d8078\f7ENDCASE => EXIT;l8738d8078\f7IN ['0..'9] => SELECT mode FROMl7468d6808\f7firstSymbol, intPart =>l8738d8078\f7BEGINl10008d9348\f7mode _ intPart;l10008d9348\f7intVal _ intVal*Ten + rcVal;l10008d9348\f7END;l10008d9348\f7fracPart =>l8738d8078\f7BEGINl10008d9348\f7fracVal _ fracVal*Ten + rcVal;l10008d9348\f7fracExp _ fracExp*Ten;l10008d9348\f7END;l10008d9348\f7firstExpSymbol, expPart =>l8738d8078\f7BEGINl10008d9348\f7mode _ expPart;l10008d9348\f7expPartV _ expPartV*10 + cVal;l10008d9348\f7END;l10008d9348\f7ENDCASE => EXIT;l8738d8078\f7ENDCASE => EXIT;l7468d6808\f7ENDLOOP;l6198d5538\f7-- now put it togetherl4928d4268\f7expVal _ One;l4928d4268\f7THROUGH [1..expPartV] DOl4928d4268\f7expVal _ expVal*Ten;l6198d5538\f7ENDLOOP;l6198d5538\f7val _ intVal+(fracVal/fracExp);l4928d4268\f7val _ IF expMinus THEN val/expVal ELSE val*expVal;l4928d4268\f7IF minus THEN val _ -val;l4928d4268\f7RETURN [val];l4928d4268\f7END;l4928d4268\f7RETURN[InsideProc[]];l4928d4268\f7END;l4928d4268\f7(635)\f7END.(1792)\f7