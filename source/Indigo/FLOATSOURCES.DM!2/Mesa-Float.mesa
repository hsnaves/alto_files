-- Mesa-Float.mesaz18591l4128d2998(1792)\f7 3b15B-- Copywrite Xerox Corporation 1980z18591l3712d2998j\f7-- Mesa implementation of floating point opsz18591l4128d2998\f7-- Last Modified: LStewart February 26, 1980  1:46 PMz18591l4128d2998\f7DIRECTORYz18591e12\f7InlineDefs: FROM "InlineDefs",z18591l4704d4268\f7Mopcodes: FROM "Mopcodes",z18591l4704d4268\f7RealDefs: FROM "RealDefs",z18591l4704d4268\f7SDDefs: FROM "SDDefs";z18591l4704d4268\f7Float: PROGRAMz18591l3658d2998e12\f7b5BIMPORTS InlineDefsz18591l4800d2998\f7EXPORTS RealDefs =z18591l4800d2998\f7BEGIN OPEN InlineDefs, RealDefs;z18591l3658d2998\f7HiBit: CARDINAL = 100000B;z18591l3658d2998\f7NotHiBit: CARDINAL = 077777B;z18591l3658d2998\f7ExponentBias: INTEGER = 128;z18591l3658d2998\f7ExponentMask: INTEGER = 077600B;z18591l3658d2998\f7ExponentShift: INTEGER = 7;z18591l3658d2998\f7ExpSingleMax: INTEGER = 127;z18591l3658d2998\f7ExpSingleMin: INTEGER = -127;z18591l3658d2998\f7SingleRound: LONG INTEGER = 0200B;z18591l3658d2998\f7PlusZero: REAL = LOOPHOLE[LONG[0]];z18591l3658d2998\f7MinusZero: REAL = LOOPHOLE[LONG[0]];z18591l3658d2998\f7PlusInfinity: REAL = LOOPHOLE[LAST[LONG INTEGER]];z18591l3658d2998\f7MinusInfinity: REAL = LOOPHOLE[-LAST[LONG INTEGER]];z18591l3658d2998\f7Extended: TYPE = RECORDz18591l3658d2998e12\f7[z18591l4928d4268\f7sign: BOOLEAN,z18591l4928d4268\f7exp: INTEGER,z18591l4928d4268\f7frac: LongNumberz18591l4928d4268\f7];z18591l4928d4268\f7FloatingPointError: PUBLIC SIGNAL[f: RealDefs.FloatingError] = CODE;z18591l3658d2998e12\f7b18B-- Add with Carryz18591l3658d2998e12\f7ADC3: PROCEDURE [a, b, c: CARDINAL] RETURNS [CARDINAL, CARDINAL] = INLINEz18591l3658d2998e12\f7b4BBEGINz18591l4928d4268\f7s: LongNumber;z18591l4928d4268\f7s.lc _ LONG[a]+LONG[b]+LONG[c];z18591l4928d4268\f7RETURN[s.highbits, s.lowbits];z18591l4928d4268\f7END;z18591l4928d4268\f7-- Add two shorts to make a longz18591l3658d2998e12\f7ADC2: PROCEDURE [a, b: CARDINAL] RETURNS [CARDINAL, CARDINAL] = INLINEz18591l3658d2998e12\f7b4BBEGINz18591l4928d4268\f7s: LongNumber;z18591l4928d4268\f7s.lc _ LONG[a]+LONG[b];z18591l4928d4268\f7RETURN[s.highbits, s.lowbits];z18591l4928d4268\f7END;z18591l4928d4268\f7LN: PROCEDURE [r: LONG UNSPECIFIED] RETURNS [LongNumber] = INLINEz18591l3658d2998e12\f7b2BBEGINz18591l4928d4268\f7RETURN[LOOPHOLE[r, LongNumber]];z18591l4928d4268\f7END;z18591l4928d4268\f7-- Separate the packed REAL into its component elementsz18591l3658d2998e12\f7Unpack: PROCEDURE [r: REAL, z: POINTER TO Extended] = INLINEz18591l3658d2998e12\f7b6BBEGINz18591l4928d4268\f7z.sign _ LOOPHOLE[LN[r].highbits, INTEGER]<0;z18591l4928d4268\f7z.frac.li _ IF z.sign THEN -LN[r].li ELSE LN[r].li;  -- Two's complement sign.z18591l4928d4268\f7z.exp _ BITSHIFT[BITAND[z.frac.highbits, ExponentMask], -ExponentShift];z18591l4928d4268\f7-- True zero is zero exponent here...z18591l4928d4268\f7IF z.exp=0 THEN z.frac.lc _ 0z18591l4928d4268\f7ELSEz18591l4928d4268\f7BEGINz18591l6198d5538\f7z.exp _ z.exp-ExponentBias;z18591l6198d5538\f7-- my own inline, z.frac _ LongShift[z.frac, 8];z18591l6198d5538\f7z.frac.highbits _ BITOR[BITSHIFT[z.frac.highbits, 8], HiBit] + BITSHIFT[z.frac.lowbits, -8];z18591l6198d5538\f7z.frac.lowbits _ BITSHIFT[z.frac.lowbits, 8];z18591l6198d5538\f7END;z18591l6198d5538\f7END;z18591l4928d4268\f7-- Stuff the components back into the packed REAL.  Manage overflow, rounding, etc.z18591l3658d2998e12\f7Pack: PROCEDURE [z: POINTER TO Extended] RETURNS [REAL] = INLINEz18591l3658d2998e12\f7b4BBEGINz18591l4928d4268\f7-- Check for Zeroz18591l4928d4268\f7IF z.frac.highbits=0 THEN RETURN [IF z.sign THEN MinusZero ELSE PlusZero];z18591l4928d4268\f7-- Roundz18591l4928d4268\f7z.frac.lc _ z.frac.lc+SingleRound;z18591l4928d4268\f7IF LOOPHOLE[z.frac.highbits, INTEGER]>=0 THENz18591l4928d4268\f7BEGINz18591l6198d5538\f7z.frac _ RSHIFT1[z.frac];z18591l6198d5538\f7-- we don't really need to set HiBit, since it is cleared belowz18591l6198d5538\f7-- z.frac.highbits _ BITOR[z.frac.highbits, HiBit];z18591l6198d5538\f7z.exp _ z.exp+1;z18591l6198d5538\f7END;z18591l6198d5538\f7-- Check for overflow conditions.z18591l4928d4268\f7IF z.exp<ExpSingleMin THEN RETURN [IF z.sign THEN MinusZero ELSE PlusZero];z18591l4928d4268\f7IF z.exp>ExpSingleMax THENz18591l4928d4268\f7BEGINz18591l6198d5538\f7SIGNAL FloatingPointError[ExponentOverflow];z18591l6198d5538\f7RETURN [IF z.sign THEN MinusInfinity ELSE PlusInfinity];z18591l6198d5538\f7END;z18591l6198d5538\f7-- my own inline version, z.frac _ LongShift[z.frac, -8];z18591l4928d4268\f7z.frac.lowbits _ BITSHIFT[z.frac.highbits, 8] +BITSHIFT[z.frac.lowbits, -8];z18591l4928d4268\f7-- clear hidden bit at same timez18591l4928d4268\f7z.frac.highbits _ BITSHIFT[BITAND[z.frac.highbits, NotHiBit], -8];z18591l4928d4268\f7z.frac.highbits _ BITOR[z.frac.highbits, BITSHIFT[z.exp+ExponentBias, ExponentShift]];z18591l4928d4268\f7RETURN [LOOPHOLE[IF z.sign THEN -z.frac.li ELSE z.frac.li, REAL]];z18591l4928d4268\f7END;z18591l4928d4268\f7-- Post Normalizez18591l3658d2998e12\f7PostNormalize: PROCEDURE [x: POINTER TO Extended] = INLINEz18591l3658d2998e12\f7b13BBEGINz18591l4928d4268\f7IF x.frac.lc=0 THEN x.exp _ 0z18591l4928d4268\f7ELSEz18591l4928d4268\f7WHILE LOOPHOLE[x.frac.highbits, INTEGER]>=0 DOz18591l6198d5538\f7-- x.frac _ LongShift[x.frac, 1];z18591l6198d5538\f7x.frac.lc _ x.frac.lc+x.frac.lc;z18591l6198d5538\f7x.exp _ x.exp-1;z18591l6198d5538\f7ENDLOOP;z18591l6198d5538\f7END;z18591l4928d4268\f7-- Works only to right (count<0 is to right)z18591l3658d2998e12\f7LongShift: PROCEDURE [y: LongNumber, count: INTEGER] RETURNS [LongNumber] = INLINEz18591l3658d2998e12\f7b9BBEGINz18591l4928d4268\f7SELECT count FROMz18591l4928d4268\f7IN (-16..0) =>z18591l6198d5538\f7BEGINz18591l7468d6808\f7y.lowbits _ BITSHIFT[y.lowbits, count] + BITSHIFT[y.highbits,count+16];z18591l7468d6808\f7y.highbits _ BITSHIFT[y.highbits, count];z18591l7468d6808\f7END;z18591l7468d6808\f7IN (-32..-16] => y _ LongNumber[num[highbits: 0, lowbits: BITSHIFT[y.highbits,count+16]]];z18591l6198d5538\f70 => NULL;z18591l6198d5538\f7<= -32 => RETURN[LongNumber[lc[lc: 0]]];z18591l6198d5538\f7ENDCASE => ERROR;z18591l6198d5538\f7RETURN[y];z18591l4928d4268\f7END;z18591l4928d4268\f7RSHIFT1: PROCEDURE [y: LongNumber] RETURNS [LongNumber] = INLINEz18591l3658d2998e12\f7b7BBEGINz18591l4928d4268\f7y.lowbits _ BITSHIFT[y.lowbits, -1];z18591l4928d4268\f7IF BITAND[y.highbits, 1]#0 THEN y.lowbits _ BITOR[y.lowbits, HiBit];z18591l4928d4268\f7y.highbits _ BITSHIFT[y.highbits, -1];z18591l4928d4268\f7RETURN[y];z18591l4928d4268\f7END;z18591l4928d4268\f7AddCommon: PROCEDURE [x, y: Extended] RETURNS [REAL] = INLINEz18591l3658d2998e12\f7b9BBEGINz18591l4928d4268\f7ediff: INTEGER _ x.exp-y.exp;z18591l4928d4268\f7IF ediff>0 THEN y.frac _ LongShift[y.frac, -ediff]z18591l4928d4268\f7ELSEz18591l4928d4268\f7BEGINz18591l6198d5538\f7x.frac _ LongShift[x.frac, ediff];z18591l6198d5538\f7x.exp _ y.exp;z18591l6198d5538\f7END;z18591l6198d5538\f7IF x.sign#y.sign THENz18591l4928d4268\f7BEGINz18591l6198d5538\f7IF x.frac.lc>=y.frac.lc THEN x.frac.lc _ x.frac.lc-y.frac.lcz18591l6198d5538\f7ELSEz18591l6198d5538\f7BEGINz18591l7468d6808\f7x.frac.lc _ y.frac.lc-x.frac.lc;z18591l7468d6808\f7x.sign _ y.sign;z18591l7468d6808\f7END;z18591l7468d6808\f7PostNormalize[@x];z18591l6198d5538\f7ENDz18591l6198d5538\f7ELSEz18591l4928d4268\f7BEGINz18591l6198d5538\f7cy: CARDINAL;z18591l6198d5538\f7[cy, x.frac.lowbits] _ ADC2[x.frac.lowbits, y.frac.lowbits];z18591l6198d5538\f7[cy, x.frac.highbits] _ ADC3[x.frac.highbits, y.frac.highbits, cy];z18591l6198d5538\f7IF cy#0 THENz18591l6198d5538\f7BEGINz18591l7468d6808\f7-- x.frac _ RSHIFT1[x.frac];z18591l7468d6808\f7x.frac.lowbits _ BITSHIFT[x.frac.lowbits, -1];z18591l7468d6808\f7IF BITAND[x.frac.highbits, 1]#0 THEN x.frac.lowbits _ BITOR[x.frac.lowbits, HiBit];z18591l7468d6808\f7x.frac.highbits _ BITOR[BITSHIFT[x.frac.highbits, -1], HiBit];z18591l7468d6808\f7x.exp _ x.exp+1;z18591l7468d6808\f7END;z18591l7468d6808\f7END;z18591l6198d5538\f7RETURN [Pack[@x]];z18591l4928d4268\f7END;z18591l4928d4268\f7FADD: PUBLIC PROCEDURE [a, b: REAL] RETURNS [REAL] =z18591l3658d2998e12\f7b4BBEGINz18591l4928d4268\f7x, y: Extended;z18591l4928d4268\f7Unpack[a, @x];z18591l4928d4268\f7IF x.frac.lc=0 THEN RETURN[b];z18591l4928d4268\f7Unpack[b, @y];z18591l4928d4268\f7IF y.frac.lc=0 THEN RETURN[a];z18591l4928d4268\f7RETURN [AddCommon[x, y]];z18591l4928d4268\f7END;z18591l4928d4268\f7FSUB: PUBLIC PROCEDURE [a, b: REAL] RETURNS [REAL] =z18591l3658d2998e12\f7b4BBEGINz18591l4928d4268\f7-- Negate bz18591l4928d4268\f7LOOPHOLE[b, LONG INTEGER] _ -LOOPHOLE[b, LONG INTEGER];z18591l4928d4268\f7RETURN [FADD[a,b]];z18591l4928d4268\f7END;z18591l4928d4268\f7FMUL: PUBLIC PROCEDURE [a, b: REAL] RETURNS [REAL] =z18591l3658d2998e12\f7b4BBEGINz18591l4928d4268\f7x, y: Extended;z18591l4928d4268\f7hi, lo, temp: LongNumber;z18591l4928d4268\f7cy: CARDINAL;z18591l4928d4268\f7Unpack[a, @x];z18591l4928d4268\f7Unpack[b, @y];z18591l4928d4268\f7x.sign _ x.sign#y.sign;z18591l4928d4268\f7x.exp _ x.exp+y.exp;z18591l4928d4268\f7-- x.frac.lc _ MedMultiply[x.frac, y.frac];z18591l4928d4268\f7lo.lc _ LongMult[x.frac.lowbits, y.frac.lowbits];z18591l4928d4268\f7hi.lc _ LongMult[x.frac.highbits, y.frac.highbits];z18591l4928d4268\f7temp.lc _ LongMult[x.frac.highbits, y.frac.lowbits];z18591l4928d4268\f7[cy, lo.highbits] _ ADC2[lo.highbits, temp.lowbits];z18591l4928d4268\f7hi.lc _ hi.lc+temp.highbits+cy;z18591l4928d4268\f7temp.lc _ LongMult[y.frac.highbits, x.frac.lowbits];z18591l4928d4268\f7[cy, lo.highbits] _ ADC2[lo.highbits, temp.lowbits];z18591l4928d4268\f7x.frac.lc _ hi.lc+temp.highbits+cy;z18591l4928d4268\f7-- normalizez18591l4928d4268\f7PostNormalize[@x];z18591l4928d4268\f7RETURN [Pack[@x]];z18591l4928d4268\f7END;z18591l4928d4268\f7FDIV: PUBLIC PROCEDURE [a, b: REAL] RETURNS [c: REAL] =z18591l3658d2998e12\f7b4BBEGINz18591l4928d4268\f7x, y: Extended;z18591l4928d4268\f7lctemp: LongNumber;z18591l4928d4268\f7Unpack[a, @x];z18591l4928d4268\f7Unpack[b, @y];z18591l4928d4268\f7x.sign _ x.sign#y.sign;z18591l4928d4268\f7IF y.frac.lc=0 THENz18591l4928d4268\f7BEGINz18591l6198d5538\f7SIGNAL FloatingPointError[DivideBy0];z18591l6198d5538\f7RETURN [IF x.sign THEN MinusInfinity ELSE PlusInfinity];z18591l6198d5538\f7END;z18591l6198d5538\f7IF x.frac.lc=0 THEN RETURN[IF x.sign THEN MinusZero ELSE PlusZero];z18591l4928d4268\f7x.exp _ x.exp-y.exp;z18591l4928d4268\f7-- Divide overflow correctionz18591l4928d4268\f7IF x.frac.highbits>=y.frac.highbits THENz18591l4928d4268\f7BEGINz18591l6198d5538\f7x.frac _ RSHIFT1[x.frac];z18591l6198d5538\f7x.exp _ x.exp+1;z18591l6198d5538\f7END;z18591l6198d5538\f7[quotient: x.frac.highbits, remainder: x.frac.lowbits] _ LongDivMod[num: x.frac.lc, den: y.frac.highbits];z18591l4928d4268\f7[quotient: x.frac.lowbits] _ LDIVMOD[numlow: 0, numhigh: x.frac.lowbits, den: y.frac.highbits];z18591l4928d4268\f7lctemp.lc _ LongMult[x.frac.highbits, y.frac.lowbits];z18591l4928d4268\f7IF lctemp.highbits>=y.frac.highbits THENz18591l4928d4268\f7BEGINz18591l6198d5538\f7x.frac.highbits _ x.frac.highbits-1;z18591l6198d5538\f7lctemp.highbits _ lctemp.highbits-y.frac.highbits;z18591l6198d5538\f7END;z18591l6198d5538\f7x.frac.lc _ x.frac.lc-LongDiv[num: lctemp.lc, den: y.frac.highbits];z18591l4928d4268\f7PostNormalize[@x];z18591l4928d4268\f7RETURN[Pack[@x]];z18591l4928d4268\f7END;z18591l4928d4268\f7FLOAT: PUBLIC PROCEDURE [a: LONG INTEGER] RETURNS [REAL] =z18591l3658d2998e12\f7b5BBEGINz18591l4928d4268\f7x: Extended;z18591l4928d4268\f7x.sign _ a<0;z18591l4928d4268\f7x.frac.li _ IF x.sign THEN -a ELSE a;z18591l4928d4268\f7IF x.frac.highbits=0 THEN  -- speed trickz18591l4928d4268\f7BEGINz18591l6198d5538\f7x.frac.highbits _ x.frac.lowbits;z18591l6198d5538\f7x.frac.lowbits _ 0;z18591l6198d5538\f7x.exp _ 16;z18591l6198d5538\f7ENDz18591l6198d5538\f7ELSE x.exp _ 32;z18591l4928d4268\f7PostNormalize[@x];z18591l4928d4268\f7RETURN[Pack[@x]];z18591l4928d4268\f7END;z18591l4928d4268\f7Fix: PUBLIC PROCEDURE [a: REAL] RETURNS [LONG INTEGER] =z18591l3658d2998e12\f7b3BBEGINz18591l4928d4268\f7x: Extended;z18591l4928d4268\f7Unpack[a, @x];z18591l4928d4268\f7IF x.exp<1 THEN RETURN[0];z18591l4928d4268\f7IF x.exp>31 THENz18591l4928d4268\f7BEGINz18591l6198d5538\f7SIGNAL FloatingPointError[FixRangeOverflow];z18591l6198d5538\f7RETURN [IF x.sign THEN FIRST[LONG INTEGER] ELSE LAST[LONG INTEGER]];z18591l6198d5538\f7END;z18591l6198d5538\f7x.frac _ LongShift[x.frac, x.exp-32];z18591l4928d4268\f7RETURN [IF x.sign THEN -x.frac.li ELSE x.frac.li];z18591l4928d4268\f7END;z18591l4928d4268\f7FixI: PUBLIC PROCEDURE [a: REAL] RETURNS [c: INTEGER] =z18591l3658d2998e12\f7b4BBEGINz18591l4928d4268\f7x: Extended;z18591l4928d4268\f7Unpack[a, @x];z18591l4928d4268\f7IF x.exp<1 THEN RETURN[0];z18591l4928d4268\f7IF x.exp>15 THENz18591l4928d4268\f7BEGINz18591l6198d5538\f7SIGNAL FloatingPointError[FixRangeOverflow];z18591l6198d5538\f7RETURN [IF x.sign THEN FIRST[INTEGER] ELSE LAST[INTEGER]];z18591l6198d5538\f7END;z18591l6198d5538\f7c _ BITSHIFT[x.frac.highbits, x.exp-16];z18591l4928d4268\f7IF x.sign THEN RETURN[-c];z18591l4928d4268\f7END;z18591l4928d4268\f7FixC: PUBLIC PROCEDURE [a: REAL] RETURNS [CARDINAL] =z18591l3658d2998e12\f7b4BBEGINz18591l4928d4268\f7x: Extended;z18591l4928d4268\f7Unpack[a, @x];z18591l4928d4268\f7IF x.exp<1 THEN RETURN[0];z18591l4928d4268\f7IF x.exp>16 THENz18591l4928d4268\f7BEGINz18591l6198d5538\f7SIGNAL FloatingPointError[FixRangeOverflow];z18591l6198d5538\f7RETURN [LAST[CARDINAL]];z18591l6198d5538\f7END;z18591l6198d5538\f7IF x.sign THENz18591l4928d4268\f7BEGINz18591l6198d5538\f7SIGNAL FloatingPointError[FixRangeOverflow];z18591l6198d5538\f7RETURN [FIRST[CARDINAL]];z18591l6198d5538\f7END;z18591l6198d5538\f7RETURN[BITSHIFT[x.frac.highbits, x.exp-16]];z18591l4928d4268\f7END;z18591l4928d4268\f7FCOMP: PROCEDURE [a,b: REAL] RETURNS [INTEGER] =z18591l3658d2998e12\f7b5BBEGINz18591l4928d4268\f7RETURN [zFComp[a,b]];z18591l4928d4268\f7END;z18591l4928d4268\f7zFComp: PROCEDURE [a,b: REAL] RETURNS [INTEGER] =z18591l3658d2998e12\f7b6BMACHINE CODE BEGIN Mopcodes.zDCOMP; END;z18591l4928d4268\f7InitFloat: PUBLIC PROCEDURE =z18591l3658d2998e12\f7b9B20f0BEGINl4268\f7 5f0SDDefs.SD[SDDefs.sFADD] _ FADD;l4268\f7 31f0SDDefs.SD[SDDefs.sFSUB] _ FSUB;l4268\f7 31f0SDDefs.SD[SDDefs.sFMUL] _ FMUL;l4268\f7 31f0SDDefs.SD[SDDefs.sFDIV] _ FDIV;l4268\f7 31f0SDDefs.SD[SDDefs.sFCOMP] _ FCOMP;l4268\f7 33f0SDDefs.SD[SDDefs.sFLOAT] _ FLOAT;l4268\f7 33f0SDDefs.SD[SDDefs.sFIX] _ Fix;l4268\f7 29f0END;l4268(635)\f7(1792)-- Mainline Code\f7 16f0InitFloat[];\f7 12f0END.z18591l3658d2998e12\f7