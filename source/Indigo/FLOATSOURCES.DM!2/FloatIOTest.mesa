-- FloatIOTest.mesal4128d2998(1792)\3b16B-- Copywrite Xerox Corporation 1980z18591l3712d2998j-- Program to check out new Floating arithmetic IOl4128d2998-- Last Modified: LStewart May 27, 1980  12:51 PMl4128d2998DIRECTORYe12InlineDefs: FROM "InlineDefs",l4704d4268IODefs: FROM "IODefs",l4704d4268RealDefs: FROM "RealDefs",l4704d4268StringDefs: FROM "StringDefs",l4704d4268WF: FROM "WF";l4704d4268FloatIOTest: PROGRAMl3658d2998e12\b11BIMPORTS IODefs, RealDefs, StringDefs, WF =l4800d2998e6BEGIN OPEN IODefs, RealDefs, StringDefs, WF;l3658d2998FloatNum: TYPE = RECORD[m2: CARDINAL, sign:[0..1], exp:[0..400B), m1:[0..200B)];l3658d2998a: REAL;l3658d2998c: CHARACTER;l3658d2998errmsg: ARRAY FloatingError OF STRING _["noError","FixExponentOverflow","ExponentOverflow","DivideBy0"];l3658d2998BEGINWFpR: PROCEDURE [p: UNSPECIFIED, form:STRING, wp: PROCEDURE[CHARACTER]] =l4256d2998\b4BBEGINl4268fp: POINTER TO REAL _ p;l4268WriteNum[fp^];l4268END;l4268(635)WriteNum: PROCEDURE [x: REAL] =l3658d2998e12(1792)\b8BBEGINl4928d4268mf: FloatNum;l4928d4268mf _ LOOPHOLE[x, FloatNum];l4714d4268WF0[" em: "];l4714d4268PrintReal[x];l4714d4268END;l4928d4268PrintReal: PROCEDURE [v: REAL] =l3658d2998e12\b9BBEGINl4928d4268man: InlineDefs.LongNumber;l4714d4268sign: BOOLEAN;l4714d4268exp: INTEGER;l4714d4268mf: FloatNum;l4928d4268mf _ LOOPHOLE[v, FloatNum];l4714d4268sign _ mf.sign=1;l4714d4268IF sign THENl4714d4268BEGINl5984d5538man.lc _ LOOPHOLE[v,LONG CARDINAL];l5984d5538man.li _ 0-man.li;l5984d5538v _ LOOPHOLE[man.lc, REAL];l5984d5538mf _ LOOPHOLE[v, FloatNum];l5984d5538END;l5984d5538man.lowbits _ mf.m2;l4714d4268man.highbits _ mf.m1+0200B;l4714d4268IF mf.exp=0 THENl4714d4268BEGINl5984d5538sign _ FALSE;l5984d5538exp _ 0;l5984d5538man.lc_0;l5984d5538ENDl5984d5538ELSE exp _ mf.exp-128;l4714d4268WF0[IF sign THEN "- " ELSE "  "];l4714d4268-- mantissa should print as 8 octal digitsl4714d4268WF2["e%4d  m.%lb", exp, @man.lc];l4714d4268END;l4928d4268-- Mainline codel3658d2998e12\3b13BSetCode[ 'R, WFpR];SetCode[ 'F, WFWriteFloat];SetCode[ 'E, WFWriteEFloat];-- WF0["*nFunction (add, imode, subtract, multiply, divide, fix, Float)*n"];c _ 'a;DO ENABLE FloatingPointError =>e12BEGINl4268WF1["*n%s*n",errmsg[f]];l4268RESUME;l4268END;l4268WF0["> "];l4268-- c _ IODefs.ReadChar[];l4268-- SELECT c FROMl4268-- 'i =>l5538BEGINl6808f: STRING _ [20];l6808s: STRING _ [60];l6808WF0[":"];l6808a _ ReadFloat[];l6808WF0[" form: "];l6808ReadID[f];l6808AppendString[s," =*nr: |%R|*nf: |%"];l6808AppendString[s,f];l6808AppendString[s,"F|*ne: |%"];l6808AppendString[s,f];l6808AppendString[s,"E|*n"];l6808WF3[s,@a,@a,@a];l6808WriteNum[a];l6808WF0["*n"];l6808END;l6808-- ENDCASE;l5538ENDLOOP;l4268END;END.l3658d2998e12