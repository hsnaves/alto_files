-- Bcpl-RealDefs.mesaz18591l3712d2998j(1792)-- Copywrite Xerox Corporation 1980z18591l3712d2998j-- Version of RealDefs for those not using floating point microcodez18591l3712d2998j-- Last Modified by L. Stewart, May 23, 1980  12:58 PMz18591l3712d2998j-- DIRECTORYe12-- Mopcodes: FROM "Mopcodes" USING [zJRAM, zLIW];l5462d4268RealDefs: DEFINITIONS =z18591l3712d2998e12j\b8BBEGINz18591l3712d2998jFloatingError: TYPE = {noError,FixRangeOverflow,ExponentOverflow,DivideBy0};z18591l3712d2998e6\b13BFloatingPointError: SIGNAL[f: FloatingError];z18591l3712d2998e6j\b18BInitFloat: PROCEDURE;z18591l3712d2998e6j\b9BWriteFloat: PROCEDURE [REAL];z18591l3712d2998e6j\b10BWFWriteFloat: PROCEDURE [rp: UNSPECIFIED, f: STRING, p: PROCEDURE [CHARACTER]];l3658d2998e6\b12BWFWriteEFloat: PROCEDURE [rp: UNSPECIFIED, f: STRING, p: PROCEDURE [CHARACTER]];l3658d2998e6\b13BAppendFloat: PROCEDURE [STRING, REAL];z18591l3712d2998e6j\b11BReadFloat: PROCEDURE RETURNS [REAL];z18591l3712d2998e6j\b9BStringToFloat: PROCEDURE [STRING] RETURNS [REAL];z18591l3712d2998e6j\b13B-- uLocFix: CARDINAL = 541B;z18591l3712d2998e6j-- uLocFixI: CARDINAL = 547B;z18591l3712d2998j-- uLocFixC: CARDINAL = 546B;z18591l3712d2998jFix: PROCEDURE [a: REAL] RETURNS [LONG INTEGER];e12\b3B-- Fix: PROCEDURE [a: REAL] RETURNS [LONG INTEGER] =e12\b6B-- MACHINE CODE BEGINl4268\b3B-- Mopcodes.zLIW, uLocFix/256, uLocFix MOD 256;l4268\b3B-- Mopcodes.zJRAM;l4268\b3B-- END;l4268(635)\b3BFixC: PROCEDURE[REAL] RETURNS [CARDINAL];z18591l3712d2998e6j(1792)\b4B-- FixC: PROCEDURE[REAL] RETURNS [CARDINAL] =z18591l3712d2998e6j\b7B-- MACHINE CODE BEGINl4268\b3B-- Mopcodes.zLIW, uLocFixC/256, uLocFixC MOD 256;l4268\b3B-- Mopcodes.zJRAM;l4268\b3B-- END;l4268(635)\b3BFixI: PROCEDURE[REAL] RETURNS [INTEGER];z18591l3712d2998e6j(1792)\b4B-- FixI: PROCEDURE[REAL] RETURNS [INTEGER] =z18591l3712d2998e6j\b7B-- MACHINE CODE BEGINl4268\b3B-- Mopcodes.zLIW, uLocFixI/256, uLocFixI MOD 256;l4268\b3B-- Mopcodes.zJRAM;l4268\b3B-- END;l4268(635)\b3BEND.z18591l3712d2998e6j(1792)