// Copywrite Xerox Corporation 1980Ftp Maxc dir/c LStewart load/c ucode-float.dmFtp Ivy dir/c Audio>RamLoad ret/c '*// do NOT recompile ucode-Realdefs!!!// Microcode versionsCompiler uFloatDefs// Put together microcodemu/l Float.muPackMu Float.mb Float.brTableCompiler MakeModule["Float.br", "uCodeImage", "uFloatDefs"]// Now do all the workCompiler MicroFloat// Configuration including RamLoad, MicroFloat, and uCodeImageBind Float/csDelete Float.br Float.ls Float.mb uCodeImage.bcd uFloatDefs.bcdDelete MicroFloat.bcdDump ucode-Float.dm @FloatBcds.cm@Ftp Maxc dir/c LStewart st/c uCode-Float.dmFtp Ivy dir/c LStewart>Float st/c uCode-Float.dm