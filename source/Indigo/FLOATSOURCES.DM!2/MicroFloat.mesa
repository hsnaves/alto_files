-- MicroFloat.mesaz18591j(1792)-- Copywrite Xerox Corporation 1980z18591l3712d2998j-- mesa interface to floating point microcodez18591j-- L. Stewart March 11, 1980  1:49 PMz18591jDIRECTORYz18591e12ControlDefs: FROM "ControlDefs" USING [StateVector],z18591l5462d4268ImageDefs: FROM "ImageDefs" USING [AddCleanupProcedure, CleanupItem, CleanupMask],z18591l5462d4268MiscDefs: FROM "MiscDefs" USING [DestroyFakeModule],z18591l5462d4268Mopcodes: FROM "Mopcodes" USING [zDCOMP, zJRAM, zLIW],z18591l5462d4268NovaOps: FROM "NovaOps" USING [CleanupReason],z18591l5462d4268RamDefs: FROM "RamDefs" USING [LoadRamAndBoot, MuImage],z18591l5462d4268RealDefs: FROM "RealDefs" USING [Fix, FloatingError],z18591l5462d4268SDDefs: FROM "SDDefs",z18591l5462d4268SegmentDefs: FROM "SegmentDefs" USING [FileSegmentAddress, FileSegmentHandle, SwapIn, SwapOut, Unlock],z18591l5462d4268uFloatDefs: FROM "uFloatDefs" USING [uCodeImage];z18591l5462d4268MicroFloat: PROGRAM IMPORTS ImageDefs, MiscDefs, RamDefs, RealDefs, SegmentDefs, uFloatDefs EXPORTS RealDefs =z18591l4672d2998e12\b10BBEGINz18591juLocFloat: CARDINAL = 540B;z18591j-- uLocFix: CARDINAL = 541B;uLocMul: CARDINAL = 542B;z18591juLocDiv: CARDINAL = 543B;z18591juLocAdd: CARDINAL = 544B;z18591juLocSub: CARDINAL = 545B;z18591jsFError: CARDINAL = 137B;z18591jfirstTime: BOOLEAN _ TRUE;z18591jcleanUpItem: ImageDefs.CleanupItem _ [NIL, ImageDefs.CleanupMask[Restore]+ImageDefs.CleanupMask[Restart], FloatCleanup];z18591l3705d2999uImageFile: SegmentDefs.FileSegmentHandle;z18591(635)uImageOffset: CARDINAL;z18591FloatingPointError: PUBLIC SIGNAL[f: RealDefs.FloatingError] = CODE;z18591l3712d2998e12(1792)\b18B-- Here are the procedures which call the mircrocode.  The only reason for having two copies is that we cannot export MACHINE CODE things directly.z18591l3648d2998e12jFFix: PROCEDURE [a: REAL] RETURNS [LONG INTEGER] =e12\b4BBEGINl4268RETURN[RealDefs.Fix[a]];l4268(635)END;l4268-- These procedures take REALs as arguments, but since we are just stuffing them into SD, they are not actually declared correctly.  The compiler produces slightly less code this way.z18591l3648d2998e12j-- PROCEDURE [LONG INTEGER] RETURNS [REAL]z18591e12jzFloat: PROCEDURE =z18591e12j\b6BBEGINz18591l4268jzzFloat[];z18591l4268jEND;z18591l4268jzzFloat: PROCEDURE =z18591l4268e12j(1792)\b7BMACHINE CODE BEGINz18591l5538jMopcodes.zLIW, uLocFloat/256, uLocFloat MOD 256;z18591l5538jMopcodes.zJRAM;z18591l5538jEND;z18591l5538j(635)-- PROCEDURE [a, b: REAL] RETURNS [INTEGER]z18591e12jFComp: PROCEDURE =z18591j\b5BBEGINz18591l4268jzFComp[];z18591l4268jEND;z18591l4268jzFComp: PROCEDURE =z18591l4268e12j(1792)\b6BMACHINE CODE BEGINz18591l5538jMopcodes.zDCOMP;z18591l5538jEND;z18591l5538j(635)-- PROCEDURE [a,b: REAL] RETURNS [REAL]z18591e12jFMul: PROCEDURE =z18591e12j\b4BBEGINz18591l4268jzFMul[];z18591l4268jEND;z18591l4268jzFMul: PROCEDURE =z18591l4268e12j(1792)\b5BMACHINE CODE BEGINz18591l5538jMopcodes.zLIW, uLocMul/256, uLocMul MOD 256;z18591l5538jMopcodes.zJRAM;z18591l5538jEND;z18591l5538j(635)FDiv: PROCEDURE =z18591e12j\b4BBEGINz18591l4268jzFDiv[];z18591l4268jEND;z18591l4268jzFDiv: PROCEDURE =z18591l4268e12j(1792)\b5BMACHINE CODE BEGINz18591l5538jMopcodes.zLIW, uLocDiv/256, uLocDiv MOD 256;z18591l5538jMopcodes.zJRAM;z18591l5538jEND;z18591l5538j(635)FAdd: PROCEDURE =z18591e12j\b4BBEGINz18591l4268jzFAdd[];z18591l4268jEND;z18591l4268jzFAdd: PROCEDURE =z18591l4268e12j(1792)\b5BMACHINE CODE BEGINz18591l5538jMopcodes.zLIW, uLocAdd/256, uLocAdd MOD 256;z18591l5538jMopcodes.zJRAM;z18591l5538jEND;z18591l5538j(635)FSub: PROCEDURE =z18591e12j\b4BBEGINz18591l4268jzFSub[];z18591l4268jEND;z18591l4268jzFSub: PROCEDURE =z18591l4268e12j(1792)\b5BMACHINE CODE BEGINz18591l5538jMopcodes.zLIW, uLocSub/256, uLocSub MOD 256;z18591l5538jMopcodes.zJRAM;z18591l5538jEND;z18591l5538j(635)--  This procedure is called directly by the microcode on error, with the stack set appropriately.  By means of the complicated ControlDefs stuff, it is possible to RESUME an operation which trapped.  FError tries to return a reasonable value on RESUME  - a vary large positive or negative value on exponent overflow, for example.z18591l3744d2998e12j(1792)FError: PROCEDURE [a: INTEGER, f: INTEGER] =z18591e12j\b6BBEGINz18591l4268jstate: ControlDefs.StateVector;z18591l4268jnf: RealDefs.FloatingError;z18591l4268jstate _ STATE;z18591l4268jnf _ SELECT f FROMz18591l5280d4268j1 => FixRangeOverflow,z18591l6550d5538j2, 4, 5, 6 => ExponentOverflow,z18591l6550d5538j3 => DivideBy0,z18591l6550d5538jENDCASE => ERROR;z18591l6550d5538jSIGNAL FloatingPointError[nf];z18591l4268jstate.instbyte _ 0;z18591l4268jstate.dest _ state.source;z18591l4268jstate.source _ 0;z18591l4268jSELECT f FROMz18591l4268j1, 2, 3 =>z18591l5538jBEGINz18591l6808jIF a>=0 THENz18591l6808jBEGINz18591l8078jstate.stk[state.stkptr] _ 177777B;z18591l8078jstate.stk[state.stkptr+1] _ 077777B; -- Most positivez18591l8078jENDz18591l8078jELSEz18591l6808jBEGINz18591l8078jstate.stk[state.stkptr] _ 000001B;z18591l8078jstate.stk[state.stkptr+1] _ 100000B; -- Most negative (almost)z18591l8078jEND;z18591l8078jstate.stkptr _ state.stkptr+1;z18591l6808jEND;z18591l6808j4 => state.stk[state.stkptr] _ LAST[CARDINAL];z18591l8352d5538j5 => state.stk[state.stkptr] _ FIRST[CARDINAL];z18591l8352d5538j6 => state.stk[state.stkptr] _ IF a>=0 THEN LAST[INTEGER] ELSE FIRST[INTEGER];z18591l7200d5538jENDCASE;z18591l5538jstate.stkptr _ state.stkptr+1;z18591l4268jRETURN WITH state; -- return from floating operationz18591l4268jEND;z18591l4268j(635)InitFloat: PUBLIC PROCEDURE =z18591e12j(1792)\b9BBEGINz18591l4268jIF firstTime THENz18591l4975d4269BEGINz18591l6245d5539firstTime _ FALSE;z18591l6245d5539-- The following piece of incredible code is intended to load the RAM from a RamImage created by PackMu and converted into a .bcd by the TableCompilerz18591l6220d5538e12j(635)-- First convert the module into a file segment.z18591l6220d5538e12j[uImageFile, uImageOffset] _ MiscDefs.DestroyFakeModule[ LOOPHOLE[uFloatDefs.uCodeImage]];z18591l6646d5538ImageDefs.AddCleanupProcedure[@cleanUpItem];z18591l6245d5539(1792)END;z18591l6245d5539LoadRam[];z18591l4268j(635)z18591l4268j(1792)-- Copy procedure descriptors into system dispatch table.z18591l4268jSDDefs.SD[SDDefs.sFADD] _ FAdd;z18591l4268jSDDefs.SD[SDDefs.sFSUB] _ FSub;z18591l4268jSDDefs.SD[SDDefs.sFMUL] _ FMul;z18591l4268jSDDefs.SD[SDDefs.sFDIV] _ FDiv;z18591l4268jSDDefs.SD[SDDefs.sFCOMP] _ FComp;z18591l4268jSDDefs.SD[SDDefs.sFLOAT] _ zFloat;z18591l4268jSDDefs.SD[SDDefs.sFIX] _ FFix;l4268SDDefs.SD[sFError] _ FError;z18591l4268jEND;z18591l4268jLoadRam: PROCEDURE =z18591l3705d2999e12\b7BBEGIN OPEN RamDefs, SegmentDefs;z18591l4268(635)uCode: MuImage;z18591l4268-- Swapin and lock the file segment containing the microcode.z18591l4950d4268e12jSwapIn[uImageFile];z18591l4268-- a MuImage is a pointer to a .br file produced by PackMu, the TableCompiler strips of the 20B word header, so we must add it back on.  With luck, this won't be below location 20B...z18591l5376d4268juCode _ LOOPHOLE[ LOOPHOLE[ FileSegmentAddress[uImageFile], CARDINAL] + uImageOffset - 20B, MuImage];z18591l5376d4268IF LoadRamAndBoot[uCode,FALSE]~=0 THEN ERROR;z18591l4268Unlock[uImageFile];z18591l4268SwapOut[uImageFile];z18591l4268END;z18591l4268FloatCleanup: PROCEDURE [why: NovaOps.CleanupReason] =z18591l3705d2999e12(1792)\b12BBEGINz18591l4975d4269LoadRam[];z18591l4975d4269END;z18591l4975d4269-- Main Line Codez18591e12j(635)InitFloat[];z18591e12jEND.z18591e12j