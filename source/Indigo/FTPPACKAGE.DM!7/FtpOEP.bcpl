// FtpOEPInit.bcpl - Ftp package Overlay Entry Point initialization// Copyright Xerox Corporation 1979, 1980, 1982// Last modified May 7, 1982  2:49 PM by Boggsexternal[// outgoing proceduresInitFTPOEP// incoming proceduresDeclareOEPGenStringProp; ScanStringProp; InitStringProp; FreeStringPropGenKeywordProp; ScanKeywordProp; InitKeywordPropGenNumberProp; ScanNumberProp; InitNumberPropGenDateProp; ScanDatePropGenBitProp; ScanBitPropLsPuts; DlsPuts; DblsPuts]//-----------------------------------------------------------------------------------------let InitFTPOEP(oepVec) be//-----------------------------------------------------------------------------------------[DeclareOEP(oepVec, lv ScanStringProp, lv GenStringProp, lv InitStringProp, lv FreeStringProp)DeclareOEP(oepVec, lv ScanKeywordProp, lv GenKeywordProp, lv InitKeywordProp)DeclareOEP(oepVec, lv ScanNumberProp, lv GenNumberProp, lv InitNumberProp)DeclareOEP(oepVec, lv ScanDateProp, lv GenDateProp)DeclareOEP(oepVec, lv ScanBitProp, lv GenBitProp)DeclareOEP(oepVec, lv LsPuts, lv DlsPuts, lv DblsPuts)]